# Copiar para .env e preencher — NUNCA commitar .env
POSTGRES_USER=kyc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=kyc_prod
RABBITMQ_USER=kyc
RABBITMQ_PASSWORD=change-me-rabbit-password
KYC_ADMIN_EMAIL=admin@kyc.local
KYC_ADMIN_PASSWORD=ChangeMe@1234
KYC_WEB_PORT=8080
OLLAMA_ENDPOINT=http://192.168.68.67:11434
KYC_DB_CONNECTION=Host=localhost;Port=5433;Database=kyc_dev;Username=postgres;Password=dev123
OPENSANCTIONS_API_KEY=
NEWSAPI_KEY=
# Identidade (webhook + polling fallback)
IDENTITY_VERIFICATION_BASE_URL=
IDENTITY_VERIFICATION_API_KEY=
IDENTITY_VERIFICATION_WEBHOOK_SECRET=
# UIF / BdP (homologação)
UIF_BASE_URL=
UIF_API_KEY=
BDP_ASSET_FREEZE_BASE_URL=
# Compliance
COMPLIANCE_ENABLE_PERIODIC_REVIEW=true
IDENTITY_VERIFICATION_ENABLE_POLLING=true
COMPLIANCE_REQUIRE_LIVE_INTEGRATIONS=false
# Entra: grupo AD com supervisores (opcional, requer app-only Graph)
COMPLIANCE_SUPERVISOR_GROUP_OBJECT_ID=
AZURE_AD_CLIENT_SECRET=
UIF_ALLOW_MANUAL_REGISTRATION=true
# Retenção RGPD (5–7 anos) — activar em produção
DATA_RETENTION_ENABLE_HOSTED_SERVICE=false
DATA_RETENTION_REJECTED_YEARS=5
DATA_RETENTION_APPROVED_YEARS=7
# OpenAPI / Swagger UI
OPENAPI_ENABLE=true
