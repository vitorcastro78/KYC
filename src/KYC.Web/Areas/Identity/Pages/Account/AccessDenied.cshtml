@page
@model KYC.Web.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Acesso negado";
    Layout = "/Pages/Shared/_LayoutAuth.cshtml";
}

<div class="auth-shell">
    <section class="auth-panel" style="grid-column: 1 / -1; max-width: 520px; margin: 0 auto;">
        <div class="auth-card">
            <div class="auth-card-header">
                <h2>Acesso negado</h2>
                <p>A sua conta está autenticada, mas não tem permissão para esta área da plataforma.</p>
            </div>
            <p class="text-muted small mb-3">
                Peça ao administrador uma das roles: <code>KYC.Analyst</code>, <code>KYC.Supervisor</code> ou <code>KYC.Admin</code>.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" href="/Identity/Account/Login">Trocar de conta</a>
                <a class="btn btn-outline-secondary" href="/Identity/Account/Logout">Terminar sessão</a>
            </div>
        </div>
    </section>
</div>
