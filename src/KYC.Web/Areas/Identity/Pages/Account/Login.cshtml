@page
@model KYC.Web.Areas.Identity.Pages.Account.LoginModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Entrar";
    Layout = "/Pages/Shared/_LayoutAuth.cshtml";
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
    var error = HttpContext.Request.Query["error"].ToString();
}

<div class="auth-shell">
    <section class="auth-hero" aria-hidden="false">
        <div class="auth-hero-content">
            <span class="auth-badge">Banking Edition</span>
            <h1>KYC Intelligence</h1>
            <p>Plataforma de due diligence corporativa, triagem de risco e compliance em tempo real.</p>
            <ul class="auth-hero-list">
                <li><span class="oi oi-check" aria-hidden="true"></span> Triagem automática de sanções e media</li>
                <li><span class="oi oi-check" aria-hidden="true"></span> Grafo UBO e relatórios auditáveis</li>
                <li><span class="oi oi-check" aria-hidden="true"></span> Workspace seguro para analistas</li>
            </ul>
        </div>
    </section>

    <section class="auth-panel">
        <div class="auth-card">
            <div class="auth-card-header">
                <h2>Bem-vindo de volta</h2>
                <p>Inicie sessão para aceder ao workspace KYC.</p>
            </div>

            @if (error == "invalid")
            {
                <div class="alert alert-danger py-2" role="alert">Email ou password incorretos.</div>
            }
            else if (error == "lockedout")
            {
                <div class="alert alert-danger py-2" role="alert">Conta bloqueada temporariamente. Tente novamente em 15 minutos.</div>
            }

            <form method="post" action="/account/login" class="auth-form">
                <input type="hidden" name="@tokens.FormFieldName" value="@tokens.RequestToken" />
                @if (!string.IsNullOrEmpty(Model.ReturnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                }

                <div class="mb-3">
                    <label class="form-label" for="email">Email</label>
                    <input id="email" name="email" type="email" class="form-control form-control-lg" autocomplete="username" placeholder="admin@kyc.local" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <input id="password" name="password" type="password" class="form-control form-control-lg" autocomplete="current-password" placeholder="••••••••" required />
                </div>

                <div class="form-check mb-3">
                    <input id="rememberMe" name="rememberMe" type="checkbox" class="form-check-input" value="true" />
                    <label class="form-check-label small" for="rememberMe">Manter sessão neste dispositivo</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 auth-submit">
                    Entrar na plataforma
                </button>
            </form>

            <div class="auth-footer">
                Ambiente demo · contacte o administrador para novas contas
            </div>
        </div>
    </section>
</div>
