@page
@model KYC.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "/Pages/Shared/_LayoutAuth.cshtml";
}

<div class="auth-shell">
    <section class="auth-hero" aria-hidden="false">
        <div class="auth-hero-content">
            <span class="auth-badge">Banking Edition</span>
            <h1>KYC Intelligence</h1>
            <p>Plataforma de due diligence corporativa, triagem de risco e compliance em tempo real.</p>
            <ul class="auth-hero-list">
                <li><span class="oi oi-check" aria-hidden="true"></span> Triagem automática de sanções e media</li>
                <li><span class="oi oi-check" aria-hidden="true"></span> Grafo UBO e relatórios auditáveis</li>
                <li><span class="oi oi-check" aria-hidden="true"></span> Workspace seguro para analistas</li>
            </ul>
        </div>
    </section>

    <section class="auth-panel">
        <div class="auth-card">
            <div class="auth-card-header">
                <h2>Bem-vindo de volta</h2>
                <p>Inicie sessão para aceder ao workspace KYC.</p>
            </div>

            <form method="post" class="auth-form" asp-route-returnUrl="@Model.ReturnUrl">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" placeholder="admin@kyc.local" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label small">Manter sessão neste dispositivo</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 auth-submit">
                    Entrar na plataforma
                </button>
            </form>

            <div class="auth-footer">
                Ambiente demo · contacte o administrador para novas contas
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
