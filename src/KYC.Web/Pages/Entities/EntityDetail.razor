@page "/entities/{PartyId:guid}"
@attribute [Authorize(Policy = "Analyst")]
@using KYC.Application.Cases
@using KYC.Application.Dtos
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Entidade</PageTitle>

@if (_party is null)
{
    <p>Entidade não encontrada.</p>
}
else
{
    <h1>@_party.Name</h1>
    <p class="text-muted">@_party.Role · NIF @_party.Nif</p>
    <EntityCard Party="_party" />
    <a class="btn btn-link" href="/cases/@_caseId">Voltar ao caso</a>
}

@code {
    [Parameter] public Guid PartyId { get; set; }
    private CasePartyDto? _party;
    private Guid _caseId;

    protected override async Task OnInitializedAsync()
    {
        var ctx = await Mediator.Send(new GetCasePartyContextQuery(PartyId));
        if (ctx is null)
            return;

        _party = ctx.Party;
        _caseId = ctx.CaseId;
    }
}
