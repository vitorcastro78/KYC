@page "/cases/{CaseId:guid}/ubo"
@attribute [Authorize(Policy = "Analyst")]
@using KYC.Application.Cases
@using KYC.Application.Dtos
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Grafo UBO — @(_graph?.CompanyName ?? "Caso")</PageTitle>

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <a class="btn btn-link ps-0" href="/cases/@CaseId">← Voltar ao caso</a>
        <h1 class="h4 mb-0">Grafo de controlo (UBO)</h1>
    </div>
    @if (_graph is not null)
    {
        <span class="badge @(_graph.HasGleifLevel2 ? "bg-success" : "bg-warning text-dark")">
            @(_graph.HasGleifLevel2 ? "GLEIF Level 2" : "Dados GLEIF limitados — partes do caso incluídas")
        </span>
    }
</div>

@if (_graph is null)
{
    <p>A carregar…</p>
}
else if (_graph.Nodes.Count == 0)
{
    <div class="alert alert-warning">Não foi possível construir o grafo para este NIF.</div>
}
else
{
    <UboGraphView Graph="_graph" CaseId="CaseId" />
}

@code {
    [Parameter] public Guid CaseId { get; set; }
    private UboGraphViewDto? _graph;

    protected override async Task OnInitializedAsync() =>
        _graph = await Mediator.Send(new GetUboGraphQuery(CaseId));
}
