@page "/help"
@page "/help/{DocId}"
@attribute [Authorize(Policy = "Analyst")]
@using KYC.Web.Services.Help
@inject IHelpDocumentationService HelpDocs
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>@PageTitleText — KYC Intelligence</PageTitle>

<div class="help-center @(ShowHome ? "help-center--home" : "help-center--article")">
    <header class="help-center-header">
        <div class="help-center-header-text">
            @if (!ShowHome && _content is not null)
            {
                <nav class="help-breadcrumb" aria-label="Navegação do manual">
                    <a href="/help">Manual</a>
                    <span class="help-breadcrumb-sep" aria-hidden="true">/</span>
                    <span>@_content.Entry.Section</span>
                </nav>
            }
            <h1 class="help-center-title">@(ShowHome ? "Manual do utilizador" : _content?.Entry.Title ?? "Manual")</h1>
            @if (ShowHome)
            {
                <p class="help-center-lead mb-0">
                    Guias passo a passo, referência por ecrã e resolução de problemas.
                </p>
            }
        </div>
        <a class="btn btn-outline-secondary btn-sm help-back-btn" href="/dashboard">
            <span class="oi oi-arrow-left me-1" aria-hidden="true"></span>
            Workspace
        </a>
    </header>

    <div class="help-center-body">
        <aside class="help-sidebar" aria-label="Índice do manual">
            <div class="help-sidebar-panel">
                <div class="help-search">
                    <span class="oi oi-magnifying-glass help-search-icon" aria-hidden="true"></span>
                    <input id="help-search"
                           class="form-control form-control-sm"
                           type="search"
                           placeholder="Pesquisar…"
                           @bind="_search"
                           @bind:event="oninput"
                           aria-label="Pesquisar no manual" />
                </div>

                <nav class="help-nav" aria-label="Artigos do manual">
                    <ul class="help-nav-list help-nav-list--top">
                        <li>
                            <NavLink class="help-nav-item help-nav-item--home" href="/help" Match="NavLinkMatch.All">
                                <span class="help-nav-icon oi oi-home" aria-hidden="true"></span>
                                <span class="help-nav-label">Início</span>
                            </NavLink>
                        </li>
                    </ul>

                    @foreach (var group in FilteredUserSections())
                    {
                        <details class="help-nav-group" open="@SectionShouldBeOpen(group.Key)">
                            <summary class="help-nav-group-title">@group.Key</summary>
                            <ul class="help-nav-list">
                                @foreach (var doc in group)
                                {
                                    <li>
                                        <NavLink class="@NavItemClass(doc)" href="@($"/help/{doc.Id}")" Match="NavLinkMatch.All" title="@doc.Description">
                                            <span class="help-nav-icon oi @doc.Icon" aria-hidden="true"></span>
                                            <span class="help-nav-label">@doc.Title</span>
                                        </NavLink>
                                    </li>
                                }
                            </ul>
                        </details>
                    }

                    <AuthorizeView Policy="Admin">
                        <details class="help-nav-group help-nav-group--tech">
                            <summary class="help-nav-group-title">Documentação técnica</summary>
                            <ul class="help-nav-list">
                                @foreach (var doc in FilteredTechnical())
                                {
                                    <li>
                                        <NavLink class="@NavItemClass(doc)" href="@($"/help/{doc.Id}")" Match="NavLinkMatch.All" title="@doc.Description">
                                            <span class="help-nav-icon oi @doc.Icon" aria-hidden="true"></span>
                                            <span class="help-nav-label">@ShortTechTitle(doc.Title)</span>
                                        </NavLink>
                                    </li>
                                }
                            </ul>
                        </details>
                    </AuthorizeView>
                </nav>
            </div>
        </aside>

        @if (!ShowHome && _content?.Headings.Count > 0)
        {
            <aside class="help-page-nav" aria-label="Nesta página">
                <div class="help-sidebar-panel help-page-nav-panel">
                    <h2 class="help-page-nav-heading">Nesta página</h2>
                    <ul class="help-page-nav-list">
                        @foreach (var h in _content.Headings)
                        {
                            <li class="@(h.Level == 3 ? "help-page-nav-item--sub" : "")">
                                <a class="help-page-nav-link"
                                   href="@InPageAnchor(h.Anchor)"
                                   @onclick="e => ScrollToAnchor(e, h.Anchor)">
                                    @h.Text
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </aside>
        }

        <div class="help-main">
            @if (ShowHome)
            {
                <div class="help-home">
                    <div class="help-home-hero card mb-4">
                        <div class="card-body">
                            <h2 class="h5 mb-2">Bem-vindo ao centro de ajuda</h2>
                            <p class="mb-3 text-muted">
                                Manual para <strong>analistas</strong> e <strong>supervisores</strong>.
                                Escolha um tema abaixo ou use o índice à esquerda.
                            </p>
                            <div class="help-quick-actions">
                                <a class="btn btn-primary btn-sm" href="/help/novo-caso">
                                    <span class="oi oi-plus me-1" aria-hidden="true"></span>
                                    Novo caso
                                </a>
                                <a class="btn btn-outline-primary btn-sm" href="/help/conformidade">Conformidade</a>
                                <a class="btn btn-outline-secondary btn-sm" href="/help/problemas">Problemas</a>
                                <a class="btn btn-outline-secondary btn-sm" href="/help/faq">FAQ</a>
                            </div>
                        </div>
                    </div>

                    @foreach (var group in HelpDocManifest.UserManualBySection())
                    {
                        <section class="help-home-section">
                            <h3 class="help-home-section-title">@group.Key</h3>
                            <div class="help-home-grid">
                                @foreach (var doc in group)
                                {
                                    <a class="help-home-card" href="@($"/help/{doc.Id}")">
                                        <span class="help-home-card-icon oi @doc.Icon" aria-hidden="true"></span>
                                        <span class="help-home-card-body">
                                            <span class="help-home-card-title">@doc.Title</span>
                                            <span class="help-home-card-desc">@doc.Description</span>
                                        </span>
                                        <span class="oi oi-chevron-right help-home-card-arrow" aria-hidden="true"></span>
                                    </a>
                                }
                            </div>
                        </section>
                    }

                    <div class="help-home-path card">
                        <div class="card-body">
                            <h3 class="h6 mb-3">Percurso sugerido</h3>
                            <ol class="help-path-steps mb-0">
                                <li><a href="/help/acesso">Acesso e perfis</a></li>
                                <li><a href="/help/novo-caso">Novo caso e triagem</a></li>
                                <li><a href="/help/conformidade">Conformidade BdP</a></li>
                                <li><a href="/help/decisoes">Decisão e relatório</a></li>
                            </ol>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <article class="help-article card">
                    @if (_loadError is not null)
                    {
                        <div class="card-body">
                            <div class="alert alert-warning mb-0" role="alert">
                                <strong>Página indisponível.</strong>
                                <p class="mb-2 small mt-2">@_loadError</p>
                                <a class="btn btn-sm btn-outline-primary" href="/help">Voltar ao início</a>
                            </div>
                        </div>
                    }
                    else if (_content is null)
                    {
                        <div class="card-body">
                            <p class="text-muted mb-0">A carregar…</p>
                        </div>
                    }
                    else
                    {
                        <div class="help-article-meta card-header">
                            <span class="badge help-article-badge">@_content.Entry.Section</span>
                            @if (!string.IsNullOrEmpty(_content.Entry.AppRoute))
                            {
                                <a class="btn btn-sm btn-primary" href="@_content.Entry.AppRoute">
                                    <span class="oi oi-external-link me-1" aria-hidden="true"></span>
                                    Abrir na aplicação
                                </a>
                            }
                        </div>
                        <div class="card-body help-markdown">
                            @((MarkupString)_content.Html)
                        </div>
                        <div class="card-footer help-article-footer">
                            <a class="help-footer-link" href="/help">
                                <span class="oi oi-arrow-left" aria-hidden="true"></span>
                                Início
                            </a>
                            @if (NextDoc() is { } next)
                            {
                                <a class="help-footer-link help-footer-link--next" href="@($"/help/{next.Id}")">
                                    @next.Title
                                    <span class="oi oi-arrow-right" aria-hidden="true"></span>
                                </a>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string? DocId { get; set; }

    private HelpDocContent? _content;
    private string? _loadError;
    private string _search = "";
    private bool _includeTechnical;
    private CancellationTokenSource? _loadCts;

    private bool ShowHome =>
        string.IsNullOrWhiteSpace(DocId) ||
        DocId.Equals(HelpDocManifest.DefaultDocId, StringComparison.OrdinalIgnoreCase);

    private string PageTitleText => ShowHome
        ? "Manual do utilizador"
        : _content?.Entry.Title ?? "Manual";

    protected override async Task OnParametersSetAsync()
    {
        if (ShowHome)
        {
            _content = null;
            _loadError = null;
            return;
        }

        await LoadDocumentAsync();
    }

    private async Task LoadDocumentAsync()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        var ct = _loadCts.Token;

        _content = null;
        _loadError = null;

        try
        {
            _includeTechnical = HelpDocManifest.Technical.Any(t =>
                string.Equals(t.Id, DocId, StringComparison.OrdinalIgnoreCase));

            _content = await HelpDocs.LoadAsync(DocId!.Trim(), _includeTechnical, ct);
            if (_content is null)
                _loadError = "Conteúdo não encontrado. Execute o build do projeto para sincronizar docs/help-online.";
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private IEnumerable<IGrouping<string, HelpDocEntry>> FilteredUserSections()
    {
        var q = _search.Trim();
        var items = string.IsNullOrWhiteSpace(q)
            ? HelpDocManifest.UserManual
            : HelpDocManifest.UserManual.Where(d => d.MatchesSearch(q));

        return items.GroupBy(d => d.Section).OrderBy(g => g.Key switch
        {
            "Começar por aqui" => 0,
            "Guia passo a passo" => 1,
            "Referência rápida" => 2,
            "Ajuda e suporte" => 3,
            _ => 99
        });
    }

    private IEnumerable<HelpDocEntry> FilteredTechnical()
    {
        var q = _search.Trim();
        return string.IsNullOrWhiteSpace(q)
            ? HelpDocManifest.Technical
            : HelpDocManifest.Technical.Where(d => d.MatchesSearch(q));
    }

    private bool SectionShouldBeOpen(string section)
    {
        if (!string.IsNullOrWhiteSpace(_search))
            return FilteredUserSections().Any(g => g.Key == section);

        if (_content is not null && _content.Entry.Section == section)
            return true;

        return section is "Guia passo a passo" or "Começar por aqui";
    }

    private string NavItemClass(HelpDocEntry doc)
    {
        var active = string.Equals(DocId, doc.Id, StringComparison.OrdinalIgnoreCase) ? " active" : "";
        return $"help-nav-item{active}";
    }

    private static string ShortTechTitle(string title) =>
        title.Split('(')[0].Trim();

    private HelpDocEntry? NextDoc()
    {
        if (_content is null)
            return null;

        var list = HelpDocManifest.UserManual.ToList();
        var idx = list.FindIndex(d => d.Id == _content.Entry.Id);
        return idx >= 0 && idx < list.Count - 1 ? list[idx + 1] : null;
    }

    private static string InPageAnchor(string anchor) => $"#help-anchor-{anchor}";

    private async Task ScrollToAnchor(MouseEventArgs e, string anchor)
    {
        await Js.InvokeVoidAsync("kycHelpScrollTo", $"help-anchor-{anchor}");
    }

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }
}
