@using Microsoft.AspNetCore.Identity
@using KYC.Web.Security
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KYC Intelligence</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/open-iconic/font/css/open-iconic-bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
<body class="identity-app-layout">
    <header class="identity-topbar">
        <div class="identity-topbar-inner">
            <a class="identity-brand" href="/dashboard">
                <span class="identity-brand-title">KYC Intelligence</span>
                <small class="identity-brand-subtitle">Banking Edition</small>
            </a>
            <nav class="identity-topbar-actions" aria-label="Conta">
                @if (SignInManager.IsSignedIn(User))
                {
                    var user = await UserManager.GetUserAsync(User);
                    <span class="identity-user-pill">
                        <span class="oi oi-person" aria-hidden="true"></span>
                        <span>@(user?.Email ?? User.Identity?.Name)</span>
                    </span>
                }
                <a class="btn btn-sm btn-outline-secondary" href="/dashboard">
                    <span class="oi oi-dashboard me-1" aria-hidden="true"></span>
                    Workspace
                </a>
                <a class="btn btn-sm btn-outline-danger" href="/Identity/Account/Logout">Sair</a>
            </nav>
        </div>
    </header>

    <main class="identity-main" id="main-content">
        @RenderBody()
    </main>

    <footer class="identity-footer">
        KYC Intelligence · ambiente demo
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
