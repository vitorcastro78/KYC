@page "/cases/{CaseId:guid}/report"
@attribute [Authorize(Policy = "Analyst")]
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Relatório KYC</PageTitle>

@if (_case?.Report is null)
{
    <p>Relatório ainda năo disponível.</p>
    <a href="/cases/@CaseId">Voltar ao caso</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Relatório — @_case.CompanyName</h1>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="/cases/@CaseId">Caso</a>
            <a class="btn btn-primary" href="@Nav.ToAbsoluteUri($"/api/cases/{CaseId}/report.pdf")" target="_blank">Exportar PDF</a>
        </div>
    </div>
    <div class="kyc-report-html border rounded bg-white p-4">
        @((MarkupString)_case.Report.Html)
    </div>
}

@code {
    [Parameter] public Guid CaseId { get; set; }
    private KYC.Application.Dtos.KycCaseDetailDto? _case;

    protected override async Task OnInitializedAsync() =>
        _case = await Mediator.Send(new GetKycCaseQuery(CaseId));
}
