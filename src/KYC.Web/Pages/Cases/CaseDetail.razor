@page "/cases/{CaseId:guid}"
@attribute [Authorize(Policy = "Analyst")]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Forms
@using KYC.Domain.Enums
@using FluentValidation
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Caso</PageTitle>

@if (_case is null)
{
    <p>A carregar…</p>
}
else
{
    <div class="case-hero mb-3">
        <div>
            <h1 class="mb-1">@_case.CompanyName</h1>
            <div class="text-muted">ID Comercial: @_case.Nif</div>
        </div>
        <div class="text-md-end">
            <div class="small text-muted">Estado do processo</div>
            <span class="status-pill @StatusClass(_case.Status)">@StatusLabel(_case.Status)</span>
            <div class="mt-2"><RiskScoreBadge Score="_case.Score" /></div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h3 class="h6 mb-0">Progresso da triagem</h3>
                <small class="text-muted">@_scanModule · @_scanPercent%</small>
            </div>
            <ScanProgressBar Module="@_scanModule" Percent="@_scanPercent" />
        </div>
    </div>

    <GleifCompanyCard Snapshot="_case.Gleif" RelatedParties="_case.GleifRelatedParties" />

    @if (!string.IsNullOrEmpty(_actionError))
    {
        <div class="alert alert-danger">@_actionError</div>
    }

    <AuthorizeView Policy="Supervisor">
        <div class="my-3 d-flex gap-2 flex-wrap">
            <button class="btn btn-success" @onclick="() => _showApprove = true">Aprovar</button>
            <button class="btn btn-danger" @onclick="() => _showReject = true">Rejeitar</button>
            <button class="btn btn-outline-secondary" @onclick="() => _showReview = true">Pedir revisão</button>
        </div>
    </AuthorizeView>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Partes associadas</h3>
            <div class="d-flex gap-2">
                @if (CanRerunAutomaticScreening(_case.Status))
                {
                    <button type="button"
                            class="btn btn-outline-warning btn-sm"
                            disabled="@_rescreenBusy"
                            @onclick="() => _showRescreen = true">
                        Refazer triagem automática
                    </button>
                }
                @if (CanAddManualParty(_case.Status))
                {
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => { ResetAddPartyForm(); _showAddParty = true; }">Adicionar parte</button>
                }
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var p in _case.Parties)
                {
                    <div class="col-md-4">
                        <EntityCard Party="p" ShowTriageButton="@CanScreenParty(_case.Status)" OnTriage="TriagemParteAsync" />
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h3 class="h6 mb-0">Sinais de risco</h3></div>
        <div class="card-body">
            @if (_case.Signals.Count == 0)
            {
                <p class="text-muted mb-0">Sem sinais registados nesta execução.</p>
            }
            else
            {
                @foreach (var s in _case.Signals)
                {
                    <SignalCard Signal="s" />
                }
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h3 class="h6 mb-0">Timeline de eventos</h3></div>
        <div class="card-body">
            @if (_timeline is not null)
            {
                <RiskTimeline Timeline="_timeline" />
            }
        </div>
    </div>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-primary" href="/cases/@CaseId/report">
            Relatório @if (_case.Report is null) { <span class="badge bg-secondary ms-1">pendente</span> }
        </a>
        <a class="btn btn-outline-secondary" href="/cases/@CaseId/ubo">Grafo UBO</a>
        <a class="btn btn-link" href="@Nav.ToAbsoluteUri($"/api/cases/{CaseId}/report.pdf")" target="_blank">PDF</a>
    </div>
}

@if (_showAddParty)
{
    <div class="modal d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Adicionar parte (quadro social, accionista, UBO…)</h5>
                    <button type="button" class="btn-close" @onclick="() => _showAddParty = false"></button>
                </div>
                <EditForm Model="_addForm" OnValidSubmit="SubmitAddPartyAsync">
                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="form-label">Nome *</label>
                            <InputText class="form-control" @bind-Value="_addForm.Name" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">NIF / identificador (opcional)</label>
                            <InputText class="form-control" @bind-Value="_addForm.Nif" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Tipo</label>
                                <InputSelect class="form-select" @bind-Value="_addForm.Type">
                                    @foreach (var t in Enum.GetValues<EntityType>())
                                    {
                                        <option value="@t">@TypeLabel(t)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Papel</label>
                                <InputSelect class="form-select" @bind-Value="_addForm.Role">
                                    @foreach (var r in Enum.GetValues<EntityRole>())
                                    {
                                        <option value="@r">@RoleLabel(r)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Participação (%)</label>
                                <InputNumber class="form-control" @bind-Value="_addForm.OwnershipPercentage" />
                            </div>
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Profundidade UBO</label>
                                <InputNumber class="form-control" @bind-Value="_addForm.UboDepthLevel" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Nacionalidade (opcional)</label>
                            <InputText class="form-control" @bind-Value="_addForm.Nationality" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Parte superior (opcional)</label>
                            <InputSelect class="form-select" @bind-Value="_addForm.ParentPartyIdStr">
                                <option value="">— Nenhuma —</option>
                                @foreach (var p in _case!.Parties)
                                {
                                    <option value="@p.Id.ToString()">@p.Name (@RoleLabel(p.Role))</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="_addForm.RunScreeningAfterAdd" id="chkScreen" />
                            <label class="form-check-label" for="chkScreen">Correr triagens (sanções, media, financeiro, judicial, ICIJ) após gravar</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showAddParty = false">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@_addPartyBusy">Guardar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<ConfirmDialog Visible="_showApprove" Title="Aprovar caso" OnConfirm="Approve" OnCancel="() => _showApprove = false">
    <p>Confirmar aprovação do caso?</p>
</ConfirmDialog>
<ConfirmDialog Visible="_showReject" Title="Rejeitar caso" OnConfirm="Reject" OnCancel="() => _showReject = false">
    <InputTextArea class="form-control" @bind-Value="_rejectReason" placeholder="Motivo" />
</ConfirmDialog>
<ConfirmDialog Visible="_showReview" Title="Revisão manual" OnConfirm="Review" OnCancel="() => _showReview = false">
    <InputTextArea class="form-control" @bind-Value="_reviewReason" placeholder="Motivo" />
</ConfirmDialog>
<ConfirmDialog Visible="_showRescreen" Title="Refazer triagem automática" OnConfirm="RerunScreeningAsync" OnCancel="() => _showRescreen = false">
    <p>
        Serão repetidas as triagens (sanções, media, financeiro, judicial, ICIJ) para <strong>todas as partes</strong>,
        sincronizadas novas entidades GLEIF quando existirem, recalculado o score e regenerado o relatório.
    </p>
    <p class="text-muted small mb-0">Sinais ainda não confirmados pelo analista serão substituídos; os confirmados mantêm-se.</p>
</ConfirmDialog>

@code {
    [Parameter] public Guid CaseId { get; set; }
    private KycCaseDetailDto? _case;
    private RiskTimelineDto? _timeline;
    private HubConnection? _hub;
    private int _scanPercent;
    private string _scanModule = "—";
    private bool _showApprove, _showReject, _showReview, _showRescreen;
    private bool _showAddParty;
    private bool _addPartyBusy;
    private bool _rescreenBusy;
    private string _rejectReason = "";
    private string _reviewReason = "";
    private string? _actionError;
    private AddPartyFormModel _addForm = new();

    private sealed class AddPartyFormModel
    {
        public string Name { get; set; } = "";
        public string? Nif { get; set; }
        public EntityType Type { get; set; } = EntityType.Individual;
        public EntityRole Role { get; set; } = EntityRole.BoardMember;
        public decimal OwnershipPercentage { get; set; }
        public int UboDepthLevel { get; set; }
        public string? Nationality { get; set; }
        public string ParentPartyIdStr { get; set; } = "";
        public bool RunScreeningAfterAdd { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await Reload();
        await RefreshScanProgressAsync();
        _timeline = await Mediator.Send(new GetRiskTimelineQuery(CaseId));

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/kyc-case"))
            .WithAutomaticReconnect()
            .Build();
        _hub.On<Guid, string, int>("ScanProgressUpdated", async (id, module, pct) =>
        {
            if (id != CaseId) return;
            _scanModule = module;
            _scanPercent = pct;
            if (pct >= 100)
                await Reload();
            await InvokeAsync(StateHasChanged);
        });
        _hub.On<Guid, string>("StatusChanged", async (id, _) =>
        {
            if (id != CaseId) return;
            await Reload();
            await InvokeAsync(StateHasChanged);
        });
        _hub.On<Guid, string>("ReportReady", async (id, _) =>
        {
            if (id != CaseId) return;
            await Reload();
            await InvokeAsync(StateHasChanged);
        });
        await _hub.StartAsync();
        await _hub.SendAsync("JoinCaseGroup", CaseId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await _hub.SendAsync("LeaveCaseGroup", CaseId);
            await _hub.DisposeAsync();
        }
    }

    private static string StatusLabel(KycStatus status) => status switch
    {
        KycStatus.Pending => "Pendente",
        KycStatus.InProgress => "Em progresso",
        KycStatus.UnderReview => "Em revisão",
        KycStatus.Approved => "Aprovado",
        KycStatus.Rejected => "Rejeitado",
        _ => status.ToString()
    };

    private static string StatusClass(KycStatus status) => status switch
    {
        KycStatus.Approved => "status-ok",
        KycStatus.Rejected => "status-bad",
        KycStatus.UnderReview => "status-warn",
        _ => "status-neutral"
    };

    private static bool CanAddManualParty(KYC.Domain.Enums.KycStatus status) =>
        status is KYC.Domain.Enums.KycStatus.InProgress or KYC.Domain.Enums.KycStatus.UnderReview or KYC.Domain.Enums.KycStatus.Approved;

    private static bool CanScreenParty(KYC.Domain.Enums.KycStatus status) =>
        status is KYC.Domain.Enums.KycStatus.InProgress or KYC.Domain.Enums.KycStatus.UnderReview or KYC.Domain.Enums.KycStatus.Approved;

    private static bool CanRerunAutomaticScreening(KYC.Domain.Enums.KycStatus status) =>
        status is KYC.Domain.Enums.KycStatus.InProgress or KYC.Domain.Enums.KycStatus.UnderReview or KYC.Domain.Enums.KycStatus.Approved;

    private void ResetAddPartyForm()
    {
        _addForm = new AddPartyFormModel();
        _actionError = null;
    }

    private async Task SubmitAddPartyAsync()
    {
        _addPartyBusy = true;
        _actionError = null;
        try
        {
            Guid? parent = null;
            if (!string.IsNullOrWhiteSpace(_addForm.ParentPartyIdStr) &&
                Guid.TryParse(_addForm.ParentPartyIdStr, out var pid))
                parent = pid;

            await Mediator.Send(new AddManualCasePartyCommand(
                CaseId,
                "dev-user",
                _addForm.Name,
                string.IsNullOrWhiteSpace(_addForm.Nif) ? null : _addForm.Nif,
                _addForm.Type,
                _addForm.Role,
                _addForm.OwnershipPercentage,
                _addForm.UboDepthLevel,
                parent,
                string.IsNullOrWhiteSpace(_addForm.Nationality) ? null : _addForm.Nationality,
                _addForm.RunScreeningAfterAdd));
            _showAddParty = false;
            await Reload();
        }
        catch (ValidationException vex)
        {
            _actionError = string.Join(" ", vex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _addPartyBusy = false;
        }
    }

    private async Task RerunScreeningAsync()
    {
        _rescreenBusy = true;
        _actionError = null;
        _scanPercent = 0;
        _scanModule = "A iniciar…";
        try
        {
            await Mediator.Send(new RerunKycCaseScreeningCommand(CaseId, "dev-user"));
            _showRescreen = false;
        }
        catch (ValidationException vex)
        {
            _actionError = string.Join(" ", vex.Errors.Select(e => e.ErrorMessage));
            _showRescreen = false;
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
            _showRescreen = false;
        }
        finally
        {
            _rescreenBusy = false;
        }
    }

    private async Task TriagemParteAsync(Guid partyId)
    {
        _actionError = null;
        try
        {
            await Mediator.Send(new ScreenCasePartyCommand(CaseId, partyId, "dev-user"));
            await Reload();
        }
        catch (ValidationException vex)
        {
            _actionError = string.Join(" ", vex.Errors.Select(e => e.ErrorMessage));
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
    }

    private async Task Approve()
    {
        await Mediator.Send(new ApproveKycCaseCommand(CaseId, "dev-user", "Aprovado"));
        _showApprove = false;
        await Reload();
    }

    private async Task Reject()
    {
        await Mediator.Send(new RejectKycCaseCommand(CaseId, "dev-user", _rejectReason));
        _showReject = false;
        await Reload();
    }

    private async Task Review()
    {
        await Mediator.Send(new RequestManualReviewCommand(CaseId, _reviewReason));
        _showReview = false;
        await Reload();
    }

    private async Task Reload()
    {
        _case = await Mediator.Send(new GetKycCaseQuery(CaseId));
        _timeline = await Mediator.Send(new GetRiskTimelineQuery(CaseId));
        await RefreshScanProgressAsync();
    }

    private async Task RefreshScanProgressAsync()
    {
        var state = await Mediator.Send(new GetKycCaseScanProgressQuery(CaseId));
        if (state is null)
            return;

        _scanPercent = state.PercentComplete;
        if (_scanPercent is > 0 and < 100)
            _scanModule = "Triagem automática em curso";
        else if (_scanPercent >= 100)
            _scanModule = "Concluído";
    }

    private static string RoleLabel(EntityRole role) => role switch
    {
        EntityRole.Target => "Tomador",
        EntityRole.Shareholder => "Accionista",
        EntityRole.Ubo => "UBO",
        EntityRole.BoardMember => "Órgão social / direcção",
        EntityRole.Proxy => "Procurador",
        _ => role.ToString()
    };

    private static string TypeLabel(EntityType type) => type switch
    {
        EntityType.Company => "Empresa",
        EntityType.Individual => "Pessoa singular",
        EntityType.Trust => "Trust",
        EntityType.Foundation => "Fundação",
        _ => type.ToString()
    };
}
