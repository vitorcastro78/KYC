    private void StartScanPolling()
    {
        StopScanPolling();
        _pollCts = new CancellationTokenSource();
        _ = PollScanProgressLoopAsync(_pollCts.Token);
    }

    private void StopScanPolling()
    {
        try
        {
            _pollCts?.Cancel();
        }
        catch
        {
            // ignore
        }

        _pollCts?.Dispose();
        _pollCts = null;
    }

    private async Task PollScanProgressLoopAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested && !_disposed && _scan.InProgress)
            {
                var completed = false;
                await DbGate.RunAsync(async () =>
                {
                    var active = await Mediator.Send(new GetKycCaseScanProgressQuery(CaseId));
                    var pct = active?.PercentComplete ?? 0;
                    var hubConnected = _hub?.State == HubConnectionState.Connected;
                    _scan.TryApplyDatabaseFallback(pct, hubConnected);

                    if (active is not null && active.PercentComplete >= 100)
                    {
                        await ReloadCoreAsync();
                        _scan.ApplyCompletedCaseView();
                        completed = true;
                    }
                });

                if (completed)
                {
                    StopScanPolling();
                    if (!_disposed)
                    {
                        Toast.Show("Triagem automática concluída.", ToastLevel.Success);
                        await InvokeAsync(StateHasChanged);
                    }

                    return;
                }

                if (!_disposed)
                    await InvokeAsync(StateHasChanged);

                await Task.Delay(2000, ct);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            // encerramento normal
        }
    }

    private void CancelReloadDebounce()
    {
        try
        {
            _reloadDebounceCts?.Cancel();
        }
        catch
        {
            // ignore
        }

        _reloadDebounceCts?.Dispose();
        _reloadDebounceCts = null;
    }

    private void RequestDebouncedReloadAsync(bool immediate = false)
    {
        if (_disposed)
            return;

        CancelReloadDebounce();
        _reloadDebounceCts = new CancellationTokenSource();
        var token = _reloadDebounceCts.Token;

        _ = InvokeAsync(async () =>
        {
            try
            {
                if (!immediate)
                    await Task.Delay(300, token);

                if (_disposed || token.IsCancellationRequested)
                    return;

                await RunDataAsync(async () =>
                {
                    await ReloadCoreAsync();
                });
                EnsureScanPollingIfNeeded();
                if (!_disposed)
                    StateHasChanged();
            }
            catch (OperationCanceledException) when (token.IsCancellationRequested)
            {
                // debounce substituído
            }
        });
    }

    private async Task ReloadCoreAsync()
    {
        _case = await Mediator.Send(new GetKycCaseQuery(CaseId));
        _timeline = await Mediator.Send(new GetRiskTimelineQuery(CaseId));
        await RefreshScanProgressAsync();
    }

    private void EnsureScanPollingIfNeeded()
    {
        if (!_disposed && _scan.InProgress && _pollCts is null)
            StartScanPolling();
    }

    private Task RunDataAsync(Func<Task> action)
    {
        if (_disposed)
            return Task.CompletedTask;

        return DbGate.RunAsync(action);
    }

    private Task Reload() => RunDataAsync(ReloadCoreAsync);

    private Task ReloadUngated() => ReloadCoreAsync();

    private async Task RefreshScanProgressAsync()
    {
        if (_case is null)
            return;

        var hubConnected = _hub?.State == HubConnectionState.Connected;

        if (_scan.InProgress)
        {
            var active = await Mediator.Send(new GetKycCaseScanProgressQuery(CaseId));
            _scan.TryApplyDatabaseFallback(active?.PercentComplete ?? 0, hubConnected);
            return;
        }

        if (IsScanFinished(_case.Status) && !_scan.InProgress)
        {
            _scan.ApplyCompletedCaseView();
            return;
        }

        if (_case.Status is KycStatus.InProgress)
        {
            var active = await Mediator.Send(new GetKycCaseScanProgressQuery(CaseId));
            var percent = active?.PercentComplete ?? 0;
            if (percent is > 0 and < 100)
                _scan.TryApplyDatabaseFallback(percent, hubConnected);
            else if (percent >= 100 && !hubConnected)
                _scan.ApplyCompletedCaseView();
            return;
        }

        if (_case.Status is KycStatus.Pending)
        {
            _scan.ApplyIdleView();
            return;
        }

        var state = await Mediator.Send(new GetKycCaseScanProgressQuery(CaseId));
        if (state is null)
        {
            _scan.ApplyIdleView();
            return;
        }

        _scan.ApplyStoredProgressView(state.PercentComplete);
    }

    private static bool IsScanFinished(KycStatus status) =>
        status is KycStatus.Approved or KycStatus.Rejected or KycStatus.UnderReview;

