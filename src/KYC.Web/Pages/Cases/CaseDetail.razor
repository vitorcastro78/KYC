@page "/cases/{CaseId:guid}"
@attribute [Authorize(Policy = "Analyst")]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Forms
@using KYC.Application.Cases
@using KYC.Application.Dtos
@using KYC.Application.Interfaces
@using KYC.Domain.Enums
@using FluentValidation
@using Microsoft.AspNetCore.SignalR.Client
@using KYC.Web.Services
@inject IMediator Mediator
@inject NavigationManager Nav
@inject KycHubConnectionFactory HubFactory
@inject ToastService Toast
@inject IConfiguration Configuration
@inject ICurrentAnalystAccessor AnalystAccessor
@inject ICircuitDbGate DbGate

<PageTitle>Caso</PageTitle>

@if (_case is null)
{
    <p>A carregar…</p>
}
else
{
    <div class="case-hero mb-3">
        <div>
            <h1 class="mb-1">@_case.CompanyName</h1>
            <div class="text-muted">ID Comercial: @_case.Nif</div>
        </div>
        <div class="text-md-end">
            <div class="small text-muted">Estado do processo</div>
            <span class="status-pill @StatusClass(_case.Status)">@StatusLabel(_case.Status)</span>
            <div class="mt-2 d-flex flex-wrap gap-1 justify-content-md-end">
                <RiskScoreBadge Score="_case.Score" />
                <span class="badge @ComplianceUiLabels.SarBadgeClass(_case.SarStatus)">@ComplianceUiLabels.SarStatusLabel(_case.SarStatus)</span>
                <span class="badge bg-light text-dark">@DdcHeroLabel(_case.DueDiligenceLevel)</span>
            </div>
        </div>
    </div>

    @if (_case.SuggestSar && _case.SarStatus != SarStatus.Submitted)
    {
        <div class="alert alert-warning py-2 mb-3">
            <strong>SAR sugerido</strong> — reveja sinais e comunique à UIF se aplicável.
            <a class="btn btn-sm btn-warning ms-2" href="#compliance-section">Ir à conformidade</a>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_case.CanApproveMessage))
    {
        <div class="alert alert-danger py-2 mb-3">@ComplianceUiLabels.FormatApproveBlockMessage(_case.CanApproveMessage)</div>
    }

    <div id="compliance-section">
        <ComplianceCaseSection Case="_case" CaseId="CaseId" OnChanged="ReloadUngated" />
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h3 class="h6 mb-0">Progresso da triagem</h3>
                <small class="text-muted">@_scan.DisplayModule · @_scan.Percent%</small>
            </div>
            <ScanProgressBar Module="@_scan.DisplayModule" Percent="@_scan.Percent" Animated="@(_scan.InProgress || _case.Status is KycStatus.InProgress)" />
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_actionError))
    {
        <div class="alert alert-danger mb-3">@_actionError</div>
    }

    <div class="card mb-3 case-actions-card">
        <div class="card-body py-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                <h3 class="h6 mb-0">Ações do caso</h3>
                <small class="text-muted">Decisão, relatórios e triagem</small>
            </div>
            <div class="case-actions-toolbar">
                <AuthorizeView Policy="Supervisor">
                    <div class="case-actions-group">
                        <span class="case-actions-label">Decisão KYC</span>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-success" disabled="@(!string.IsNullOrWhiteSpace(_case?.CanApproveMessage))" @onclick="() => _showApprove = true">Aprovar</button>
                            <button type="button" class="btn btn-danger" @onclick="() => _showReject = true">Rejeitar</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => _showReview = true">Pedir revisão</button>
                        </div>
                    </div>
                </AuthorizeView>
                <div class="case-actions-group">
                    <span class="case-actions-label">Relatórios</span>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-primary" href="/cases/@CaseId/report">
                            Relatório @if (_case.Report is null) { <span class="badge bg-secondary ms-1">pendente</span> }
                        </a>
                        <a class="btn btn-outline-secondary" href="/cases/@CaseId/ubo">Grafo UBO</a>
                        <a class="btn btn-outline-secondary" href="@Nav.ToAbsoluteUri($"/api/cases/{CaseId}/report.pdf")" target="_blank">PDF</a>
                    </div>
                </div>
                @if (CanRerunAutomaticScreening(_case.Status))
                {
                    <div class="case-actions-group">
                        <span class="case-actions-label">Triagem</span>
                        <button type="button"
                                class="btn btn-outline-warning"
                                disabled="@_rescreenBusy"
                                @onclick="() => _showRescreen = true">
                            Refazer triagem automática
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <GleifCompanyCard Snapshot="_case.Gleif" RelatedParties="_case.GleifRelatedParties" />

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Grafo de controlo (UBO)</h3>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleUboPreview">
                    @(_uboExpanded ? "Recolher" : "Expandir")
                </button>
                <a class="btn btn-sm btn-outline-primary" href="/cases/@CaseId/ubo">Ecrã completo</a>
            </div>
        </div>
        @if (_uboExpanded)
        {
            <div class="card-body pt-0">
                @if (_uboGraph is null)
                {
                    <p class="text-muted small mb-0">A carregar grafo…</p>
                }
                else if (_uboGraph.Nodes.Count == 0)
                {
                    <p class="text-muted small mb-0">Sem dados de grafo disponíveis.</p>
                }
                else
                {
                    <UboGraphView Graph="_uboGraph" CaseId="CaseId" Compact="true" />
                }
            </div>
        }
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Partes associadas</h3>
            <div class="d-flex gap-2">
                @if (CanAddManualParty(_case.Status))
                {
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => { ResetAddPartyForm(); _showAddParty = true; }">Adicionar parte</button>
                }
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var p in _case.Parties)
                {
                    <div class="col-md-4">
                        <EntityCard Party="p" CaseId="CaseId" ShowTriageButton="@CanScreenParty(_case.Status)" OnTriage="TriagemParteAsync" />
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Documentos da entidade</h3>
            @if (_case.Status is not KycStatus.Rejected)
            {
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => _showUploadDocument = true">
                    Carregar documento
                </button>
            }
        </div>
        <div class="card-body">
            @if (_case.Documents.Count == 0)
            {
                <p class="text-muted mb-0">Nenhum documento carregado.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Ficheiro</th>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th>Data</th>
                                <th>Dados extraídos</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in _case.Documents)
                            {
                                <tr>
                                    <td>@doc.FileName</td>
                                    <td>@DocumentKindLabel(doc.DocumentKind)</td>
                                    <td><span class="badge @DocumentStatusBadge(doc.IngestionStatus)">@DocumentStatusLabel(doc.IngestionStatus)</span></td>
                                    <td class="text-nowrap small">@doc.UploadedAt.ToLocalTime().ToString("g")</td>
                                    <td class="small">
                                        @if (doc.Facts.Count > 0 || doc.Parties.Count > 0)
                                        {
                                            @foreach (var f in doc.Facts.Take(4))
                                            {
                                                <div><strong>@f.FactKey:</strong> @f.FactValue</div>
                                            }
                                            @if (doc.Parties.Count > 0)
                                            {
                                                <div class="text-muted">@doc.Parties.Count parte(s) declarada(s)</div>
                                            }
                                        }
                                        else if (doc.IngestionStatus == DocumentIngestionStatus.Failed)
                                        {
                                            <span class="text-danger">@doc.FailureReason</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-nowrap">
                                        <a class="btn btn-link btn-sm p-0 me-2" href="@Nav.ToAbsoluteUri($"/api/cases/{CaseId}/documents/{doc.Id}/file")" target="_blank">Original</a>
                                        @if (doc.HasExtractedText)
                                        {
                                            <a class="btn btn-link btn-sm p-0" href="@Nav.ToAbsoluteUri($"/api/cases/{CaseId}/documents/{doc.Id}/text")" target="_blank">Texto</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Sinais de risco</h3>
            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => _showManualSignal = true">
                Registar sinal manual
            </button>
        </div>
        <div class="card-body">
            <p class="small text-muted">
                Triagem automática (media, judicial, sanções, etc.) pode falhar ou estar indisponível —
                confirme ou descarte o que apareceu e registe sinais complementares quando necessário.
            </p>
            @if (_case.Signals.Count == 0)
            {
                <p class="text-muted mb-0">Sem sinais registados nesta execução.</p>
            }
            else
            {
                @foreach (var group in _case.Signals
                    .GroupBy(s => s.PartyName ?? "Caso / entidade principal")
                    .OrderBy(g => g.Key))
                {
                    <h6 class="text-muted small text-uppercase mt-3 mb-2">@group.Key</h6>
                    @foreach (var s in group.OrderByDescending(x => x.DetectedAt))
                    {
                        <SignalCard Signal="s" CaseId="CaseId" OnChanged="ReloadUngated" />
                    }
                }
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h3 class="h6 mb-0">Timeline de eventos</h3></div>
        <div class="card-body">
            @if (_timeline is not null)
            {
                <RiskTimeline Timeline="_timeline" />
            }
        </div>
    </div>
}

@if (_showManualSignal)
{
    <div class="modal d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Sinal de risco manual</h5>
                    <button type="button" class="btn-close" @onclick="() => _showManualSignal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Tipo</label>
                        <select class="form-select" @bind="_manualSignalType">
                            @foreach (var t in Enum.GetValues<SignalType>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Severidade</label>
                        <select class="form-select" @bind="_manualSignalSeverity">
                            @foreach (var s in Enum.GetValues<SignalSeverity>())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Fonte</label>
                        <input class="form-control" @bind="_manualSignalSource" placeholder="Ex.: Consulta judicial, imprensa" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Descrição</label>
                        <textarea class="form-control" rows="3" @bind="_manualSignalDescription" placeholder="Mín. 10 caracteres"></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Parte associada (opcional)</label>
                        <select class="form-select" @bind="_manualSignalPartyIdStr">
                            <option value="">— Caso / entidade —</option>
                            @foreach (var p in _case!.Parties)
                            {
                                <option value="@p.Id.ToString()">@p.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showManualSignal = false">Cancelar</button>
                    <button type="button" class="btn btn-primary" disabled="@_manualSignalBusy" @onclick="SubmitManualSignalAsync">Registar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showAddParty)
{
    <div class="modal d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Adicionar parte (quadro social, accionista, UBO…)</h5>
                    <button type="button" class="btn-close" @onclick="() => _showAddParty = false"></button>
                </div>
                <EditForm Model="_addForm" OnValidSubmit="SubmitAddPartyAsync">
                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="form-label">Nome *</label>
                            <InputText class="form-control" @bind-Value="_addForm.Name" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">NIF / identificador (opcional)</label>
                            <InputText class="form-control" @bind-Value="_addForm.Nif" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Tipo</label>
                                <InputSelect class="form-select" @bind-Value="_addForm.Type">
                                    @foreach (var t in Enum.GetValues<EntityType>())
                                    {
                                        <option value="@t">@TypeLabel(t)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Papel</label>
                                <InputSelect class="form-select" @bind-Value="_addForm.Role">
                                    @foreach (var r in Enum.GetValues<EntityRole>())
                                    {
                                        <option value="@r">@RoleLabel(r)</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Participação (%)</label>
                                <InputNumber class="form-control" @bind-Value="_addForm.OwnershipPercentage" />
                            </div>
                            <div class="col-md-6 mb-2">
                                <label class="form-label">Profundidade UBO</label>
                                <InputNumber class="form-control" @bind-Value="_addForm.UboDepthLevel" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Nacionalidade (opcional)</label>
                            <InputText class="form-control" @bind-Value="_addForm.Nationality" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Parte superior (opcional)</label>
                            <InputSelect class="form-select" @bind-Value="_addForm.ParentPartyIdStr">
                                <option value="">— Nenhuma —</option>
                                @foreach (var p in _case!.Parties)
                                {
                                    <option value="@p.Id.ToString()">@p.Name (@RoleLabel(p.Role))</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="_addForm.RunScreeningAfterAdd" id="chkScreen" />
                            <label class="form-check-label" for="chkScreen">Correr triagens (sanções, media, financeiro, judicial, ICIJ) após gravar</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showAddParty = false">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@_addPartyBusy">Guardar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<ConfirmDialog Visible="_showApprove"
               Title="Aprovar caso"
               ConfirmDisabled="@(!CanConfirmApprove())"
               ConfirmLabel="Aprovar"
               OnConfirm="Approve"
               OnCancel="() => _showApprove = false">
    @if (!string.IsNullOrWhiteSpace(_case?.CanApproveMessage))
    {
        <div class="alert alert-danger mb-0">@ComplianceUiLabels.FormatApproveBlockMessage(_case.CanApproveMessage)</div>
    }
    else
    {
        <p>Confirmar aprovação do caso?</p>
        @if (_case?.DueDiligenceLevel == DueDiligenceLevel.Enhanced)
        {
            <div class="mb-2">
                <label class="form-label">Segundo aprovador (4-eyes EDD) *</label>
                @if (_supervisors.Count > 0)
                {
                    <select class="form-select" @bind="_secondApproverId">
                        <option value="">— Seleccionar supervisor —</option>
                        @foreach (var s in _supervisors)
                        {
                            <option value="@s.Id">@s.DisplayName (@s.Email)</option>
                        }
                    </select>
                }
                else
                {
                    <input class="form-control" @bind="_secondApproverId" placeholder="ID do supervisor" />
                }
            </div>
        }
    }
</ConfirmDialog>
<ConfirmDialog Visible="_showReject" Title="Rejeitar caso" OnConfirm="Reject" OnCancel="() => _showReject = false">
    <InputTextArea class="form-control" @bind-Value="_rejectReason" placeholder="Motivo" />
</ConfirmDialog>
<ConfirmDialog Visible="_showReview" Title="Revisão manual" OnConfirm="Review" OnCancel="() => _showReview = false">
    <InputTextArea class="form-control" @bind-Value="_reviewReason" placeholder="Motivo" />
</ConfirmDialog>
<ConfirmDialog Visible="_showRescreen" Title="Refazer triagem automática" OnConfirm="RerunScreeningAsync" OnCancel="() => _showRescreen = false">
    <p>
        Serão repetidas as triagens (sanções, media, financeiro, judicial, ICIJ) para <strong>todas as partes</strong>,
        sincronizadas novas entidades GLEIF quando existirem, recalculado o score e regenerado o relatório.
    </p>
    <p class="text-muted small mb-0">Sinais ainda não confirmados pelo analista serão substituídos; os confirmados mantêm-se.</p>
</ConfirmDialog>

@if (_showUploadDocument)
{
    <div class="modal d-block bg-dark bg-opacity-50" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Carregar documento</h5>
                    <button type="button" class="btn-close" @onclick="() => _showUploadDocument = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Ficheiro *</label>
                        <InputFile class="form-control" OnChange="OnDocumentFileSelected" accept=".pdf,.docx,.jpg,.jpeg,.png,.tif,.tiff" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Tipo de documento</label>
                        <InputSelect class="form-select" @bind-Value="_uploadForm.Kind">
                            @foreach (var k in Enum.GetValues<CaseDocumentKind>())
                            {
                                <option value="@k">@DocumentKindLabel(k)</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Associar a parte (opcional)</label>
                        <InputSelect class="form-select" @bind-Value="_uploadForm.CasePartyIdStr">
                            <option value="">— Entidade do caso —</option>
                            @foreach (var p in _case!.Parties)
                            {
                                <option value="@p.Id.ToString()">@p.Name (@RoleLabel(p.Role))</option>
                            }
                        </InputSelect>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showUploadDocument = false">Cancelar</button>
                    <button type="button" class="btn btn-primary" disabled="@(_uploadBusy || _uploadFile is null)" @onclick="SubmitUploadDocumentAsync">Enviar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid CaseId { get; set; }
    private KycCaseDetailDto? _case;
    private RiskTimelineDto? _timeline;
    private HubConnection? _hub;
    private bool _hubHandlersRegistered;
    private CancellationTokenSource? _pollCts;
    private CancellationTokenSource? _reloadDebounceCts;
    private readonly ScanProgressTracker _scan = new();
    private bool _disposed;
    private bool _showApprove, _showReject, _showReview, _showRescreen;
    private bool _showAddParty;
    private bool _showManualSignal;
    private bool _manualSignalBusy;
    private SignalType _manualSignalType = SignalType.AdverseMedia;
    private SignalSeverity _manualSignalSeverity = SignalSeverity.Medium;
    private string _manualSignalSource = "";
    private string _manualSignalDescription = "";
    private string _manualSignalPartyIdStr = "";
    private bool _showUploadDocument;
    private bool _addPartyBusy;
    private bool _uploadBusy;
    private bool _rescreenBusy;
    private IBrowserFile? _uploadFile;
    private UploadDocumentFormModel _uploadForm = new();
    private string _rejectReason = "";
    private string _reviewReason = "";
    private string _secondApproverId = "";
    private IReadOnlyList<SupervisorUserDto> _supervisors = [];
    private string? _actionError;
    private AddPartyFormModel _addForm = new();
    private bool _uboExpanded;
    private UboGraphViewDto? _uboGraph;
    private bool _uboLoadStarted;

    private Task<string> AnalystIdAsync() => AnalystAccessor.GetAnalystIdAsync();

    private async Task ToggleUboPreview()
    {
        _uboExpanded = !_uboExpanded;
        if (_uboExpanded && !_uboLoadStarted)
        {
            _uboLoadStarted = true;
            await RunDataAsync(async () =>
            {
                _uboGraph = await Mediator.Send(new GetUboGraphQuery(CaseId));
            });
        }
    }

    private sealed class AddPartyFormModel
    {
        public string Name { get; set; } = "";
        public string? Nif { get; set; }
        public EntityType Type { get; set; } = EntityType.Individual;
        public EntityRole Role { get; set; } = EntityRole.BoardMember;
        public decimal OwnershipPercentage { get; set; }
        public int UboDepthLevel { get; set; }
        public string? Nationality { get; set; }
        public string ParentPartyIdStr { get; set; } = "";
        public bool RunScreeningAfterAdd { get; set; } = true;
    }

    private sealed class UploadDocumentFormModel
    {
        public CaseDocumentKind Kind { get; set; } = CaseDocumentKind.Other;
        public string CasePartyIdStr { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await DbGate.RunAsync(async () =>
        {
            try
            {
                _supervisors = await Mediator.Send(new GetSupervisorUsersQuery());
            }
            catch
            {
                _supervisors = [];
            }

            await ReloadCoreAsync();
        });

        EnsureScanPollingIfNeeded();
        await ConnectHubAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await ConnectHubAsync();
    }

    private async Task ConnectHubAsync()
    {
        if (_hub?.State == HubConnectionState.Connected)
            return;

        try
        {
            _hub ??= HubFactory.Create();
            if (!_hubHandlersRegistered)
            {
                _hubHandlersRegistered = true;
            _hub.On<Guid, string, int>("ScanProgressUpdated", (id, module, pct) =>
            {
                if (id != CaseId || _disposed) return;
                _ = InvokeAsync(async () =>
                {
                    if (_disposed) return;
                    var result = _scan.ApplyHubUpdate(module, pct);
                    if (result == ScanProgressHubResult.Failed)
                    {
                        StopScanPolling();
                        _actionError = "A triagem automática falhou. Consulte os logs do servidor ou tente novamente.";
                        RequestDebouncedReloadAsync();
                        return;
                    }

                    if (result == ScanProgressHubResult.IgnoredStale)
                        return;

                    if (result == ScanProgressHubResult.Completed)
                    {
                        StopScanPolling();
                        Toast.Show("Triagem automática concluída.", ToastLevel.Success);
                        RequestDebouncedReloadAsync();
                    }

                    StateHasChanged();
                });
            });
            _hub.On<Guid, string>("StatusChanged", (id, status) =>
            {
                if (id != CaseId || _disposed) return;
                _ = InvokeAsync(() =>
                {
                    if (_disposed || _scan.InProgress)
                        return Task.CompletedTask;

                    RequestDebouncedReloadAsync();
                    return Task.CompletedTask;
                });
            });
            _hub.On<Guid, string>("ReportReady", (id, status) =>
            {
                if (id != CaseId || _disposed) return;
                _ = InvokeAsync(() =>
                {
                    if (_disposed) return Task.CompletedTask;

                    StopScanPolling();
                    _scan.ApplyCompletedCaseView();
                    Toast.Show("Relatório KYC disponível.", ToastLevel.Success);
                    RequestDebouncedReloadAsync(immediate: true);
                    return Task.CompletedTask;
                });
            });
            _hub.On<Guid, Guid, string>("DocumentIngestionUpdated", (id, documentId, status) =>
            {
                if (id != CaseId || _disposed) return;
                _ = InvokeAsync(() =>
                {
                    if (_disposed) return Task.CompletedTask;

                    RequestDebouncedReloadAsync();
                    return Task.CompletedTask;
                });
            });
            }

            if (_hub.State == HubConnectionState.Disconnected)
                await _hub.StartAsync();

            if (_hub.State == HubConnectionState.Connected)
                await _hub.SendAsync("JoinCaseGroup", CaseId);
            try
            {
                await _hub.SendAsync("JoinSupervisorsGroup");
            }
            catch
            {
                // Analistas sem role Supervisor ignoram este grupo.
            }
        }
        catch
        {
            // Atualizações em tempo real indisponíveis; a página continua utilizável.
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        StopScanPolling();
        CancelReloadDebounce();

        if (_hub is not null)
        {
            try
            {
                if (_hub.State == HubConnectionState.Connected)
                    await _hub.SendAsync("LeaveCaseGroup", CaseId);
            }
            catch
            {
                // ignore on teardown
            }

            await _hub.DisposeAsync();
        }
    }

