@page "/cases"
@attribute [Authorize(Policy = "Analyst")]
@using KYC.Web.Services
@inject IMediator Mediator

<PageTitle>Casos</PageTitle>

<div class="cases-header mb-3">
    <div>
        <h1 class="mb-1">Carteira de Casos KYC</h1>
        <p class="text-muted mb-0">Visão consolidada de onboarding, monitorização e decisão de risco.</p>
    </div>
    <a class="btn btn-primary" href="/cases/new">Novo caso</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-corporate mb-0">
                <thead>
                <tr><th>Identificador</th><th>Empresa</th><th>Score</th><th>DDC</th><th>SAR</th><th>Estado</th><th>Criado</th></tr>
                </thead>
                <tbody>
                @foreach (var c in _items)
                {
                    <tr>
                        <td><a class="fw-semibold" href="/cases/@c.Id">@c.Nif</a></td>
                        <td>@c.CompanyName</td>
                        <td><RiskScoreBadge Score="c.Score" /></td>
                        <td><span class="badge bg-light text-dark">@DdcLabel(c.DueDiligenceLevel)</span></td>
                        <td><span class="badge @ComplianceUiLabels.SarBadgeClass(c.SarStatus)">@ComplianceUiLabels.SarListLabel(c.SarStatus)</span></td>
                        <td><span class="status-pill @StatusClass(c.Status)">@StatusLabel(c.Status)</span></td>
                        <td>@c.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<KycCaseDto> _items = new();

    protected override async Task OnInitializedAsync()
    {
        var page = await Mediator.Send(new ListKycCasesQuery(new KycCaseFilter(Page: 1, PageSize: 50)));
        _items = page.Items.ToList();
    }

    private static string StatusLabel(KycStatus status) => status switch
    {
        KycStatus.Pending => "Pendente",
        KycStatus.InProgress => "Em progresso",
        KycStatus.UnderReview => "Em revisão",
        KycStatus.Approved => "Aprovado",
        KycStatus.Rejected => "Rejeitado",
        _ => status.ToString()
    };

    private static string DdcLabel(DueDiligenceLevel d) => d switch
    {
        DueDiligenceLevel.Simplified => "Simplificada",
        DueDiligenceLevel.Enhanced => "Reforçada",
        _ => "Standard"
    };

    private static string StatusClass(KycStatus status) => status switch
    {
        KycStatus.Approved => "status-ok",
        KycStatus.Rejected => "status-bad",
        KycStatus.UnderReview => "status-warn",
        _ => "status-neutral"
    };
}
