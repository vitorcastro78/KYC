@page "/cases"
@attribute [Authorize(Policy = "Analyst")]
@inject IMediator Mediator

<PageTitle>Casos</PageTitle>
<h1>Casos KYC</h1>
<a class="btn btn-primary mb-3" href="/cases/new">Novo caso</a>

<table class="table table-striped">
    <thead><tr><th>NIF</th><th>Empresa</th><th>Score</th><th>Estado</th><th>Criado</th></tr></thead>
    <tbody>
    @foreach (var c in _items)
    {
        <tr>
            <td><a href="/cases/@c.Id">@c.Nif</a></td>
            <td>@c.CompanyName</td>
            <td><RiskScoreBadge Score="c.Score" /></td>
            <td>@c.Status</td>
            <td>@c.CreatedAt.ToLocalTime()</td>
        </tr>
    }
    </tbody>
</table>

@code {
    private List<KycCaseDto> _items = new();

    protected override async Task OnInitializedAsync()
    {
        var page = await Mediator.Send(new ListKycCasesQuery(new KycCaseFilter(Page: 1, PageSize: 50)));
        _items = page.Items.ToList();
    }
}
