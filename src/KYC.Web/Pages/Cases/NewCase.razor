@page "/cases/new"
@attribute [Authorize(Policy = "Analyst")]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using KYC.Web.Services
@inject IMediator Mediator
@inject NavigationManager Nav
@inject KycHubConnectionFactory HubFactory

<PageTitle>Novo caso</PageTitle>
<h1>Abrir caso KYC</h1>

<EditForm Model="_model" OnValidSubmit="Submit">
    <fieldset disabled="@_isProcessing">
        <div class="mb-3">
            <label class="form-label">NIF / NIPC ou nome da entidade</label>
            <InputText class="form-control" @bind-Value="_model.Nif" placeholder="Ex.: 508144500 ou Acme Portugal Lda." />
        </div>
        <div class="mb-3">
            <label class="form-label">Montante solicitado (EUR)</label>
            <InputNumber class="form-control" @bind-Value="_model.Amount" />
        </div>
        <button class="btn btn-primary" type="submit" disabled="@_isProcessing">
            @if (_isProcessing)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>A processar…</span>
            }
            else
            {
                <span>Iniciar</span>
            }
        </button>
    </fieldset>
</EditForm>

@if (_isProcessing)
{
    <div class="card mt-4 border-primary">
        <div class="card-body">
            <h2 class="h6 mb-3">Triagem automática em curso</h2>
            <p class="text-muted small mb-2">
                @if (_pendingCaseId is null)
                {
                    <span>A criar o caso e a resolver a entidade…</span>
                }
                else
                {
                    <span>Será redireccionado para o caso quando o processo terminar.</span>
                }
            </p>
            <ScanProgressBar Module="@_scan.DisplayModule" Percent="@_scan.Percent" Animated="true" />
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger mt-3">@_error</div>
}

@code {
    private readonly CaseForm _model = new();
    private readonly ScanProgressTracker _scan = new();
    private string? _error;
    private bool _isProcessing;
    private bool _disposed;
    private Guid? _pendingCaseId;
    private HubConnection? _hub;
    private bool _hubHandlersRegistered;
    private CancellationTokenSource? _pollCts;

    private async Task Submit()
    {
        if (_isProcessing)
            return;

        _error = null;
        _isProcessing = true;
        _pendingCaseId = null;
        _scan.BeginNewCaseFlow();
        StopPolling();

        try
        {
            var id = await Mediator.Send(new StartKycCaseCommand(_model.Nif, "dev-user", CreditAmount.Eur(_model.Amount)));
            _pendingCaseId = id;
            _scan.ApplyNewCaseCreatedHint();

            await TryConnectHubAsync(id);
            StartPolling(id);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _isProcessing = false;
            _pendingCaseId = null;
            _scan.ResetAfterFailure();
            StopPolling();
        }
    }

    private void StartPolling(Guid caseId)
    {
        StopPolling();
        _pollCts = new CancellationTokenSource();
        _ = PollProgressLoopAsync(caseId, _pollCts.Token);
    }

    private void StopPolling()
    {
        try
        {
            _pollCts?.Cancel();
        }
        catch
        {
            // ignore
        }

        _pollCts?.Dispose();
        _pollCts = null;
    }

    private async Task PollProgressLoopAsync(Guid caseId, CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested && !_disposed)
            {
                await RefreshProgressFromDatabaseAsync(caseId);

                if (await TryCompleteAndNavigateAsync(caseId))
                    return;

                await Task.Delay(2000, ct);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            // encerramento normal
        }
    }

    private async Task RefreshProgressFromDatabaseAsync(Guid caseId)
    {
        if (_disposed)
            return;

        var hubConnected = _hub?.State == HubConnectionState.Connected;
        if (hubConnected)
            return;

        var active = await Mediator.Send(new GetKycCaseScanProgressQuery(caseId));
        var pct = active?.PercentComplete ?? 0;

        await InvokeAsync(() =>
        {
            if (_disposed)
                return Task.CompletedTask;

            _scan.TryApplyDatabaseFallback(pct, hubConnected: false);
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private async Task<bool> TryCompleteAndNavigateAsync(Guid caseId)
    {
        if (_disposed)
            return true;

        var kyc = await Mediator.Send(new GetKycCaseQuery(caseId));
        if (kyc?.Report is null)
            return false;

        StopPolling();
        await InvokeAsync(() =>
        {
            if (_disposed)
                return Task.CompletedTask;

            _scan.ApplyCompletedCaseView();
            Nav.NavigateTo($"/cases/{caseId}", true);
            return Task.CompletedTask;
        });

        return true;
    }

    private async Task TryConnectHubAsync(Guid caseId)
    {
        try
        {
            _hub ??= HubFactory.Create();
            RegisterHubHandlers();

            if (_hub.State == HubConnectionState.Disconnected)
                await _hub.StartAsync();

            if (_hub.State == HubConnectionState.Connected)
                await _hub.SendAsync("JoinCaseGroup", caseId);
        }
        catch
        {
            // SignalR opcional; polling à BD cobre progresso e conclusão.
        }
    }

    private void RegisterHubHandlers()
    {
        if (_hub is null || _hubHandlersRegistered)
            return;

        _hubHandlersRegistered = true;

        _hub.On<Guid, string, int>("ScanProgressUpdated", (id, module, pct) =>
        {
            if (_pendingCaseId is null || id != _pendingCaseId || _disposed)
                return;

            _ = InvokeAsync(() =>
            {
                var result = _scan.ApplyHubUpdate(module, pct);
                if (result == ScanProgressHubResult.Failed)
                {
                    _error = "A triagem automática falhou. Consulte os logs do servidor ou abra o caso na lista.";
                    _isProcessing = false;
                    _pendingCaseId = null;
                    _scan.ResetAfterFailure();
                    StopPolling();
                }

                StateHasChanged();
                return Task.CompletedTask;
            });
        });

        _hub.On<Guid, string>("ReportReady", OnReportReady);
    }

    private void OnReportReady(Guid id, string status)
    {
        if (_pendingCaseId is null || id != _pendingCaseId || _disposed)
            return;

        _ = InvokeAsync(HandleReportReadyAsync);
    }

    private async Task HandleReportReadyAsync()
    {
        if (_pendingCaseId is not { } caseId || _disposed)
            return;

        StopPolling();
        await TryCompleteAndNavigateAsync(caseId);
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        StopPolling();

        if (_hub is null)
            return;

        if (_pendingCaseId is { } caseId)
        {
            try
            {
                if (_hub.State == HubConnectionState.Connected)
                    await _hub.SendAsync("LeaveCaseGroup", caseId);
            }
            catch
            {
                // ignore on teardown
            }
        }

        await _hub.DisposeAsync();
    }

    private sealed class CaseForm
    {
        public string Nif { get; set; } = "";
        public decimal Amount { get; set; } = 100000;
    }
}
