@page "/admin/aml-report"
@attribute [Authorize(Policy = "Admin")]
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>RPB — Relatório BdP</PageTitle>
<h1>Relatório de Prevenção do Branqueamento (Instrução BdP 8/2024)</h1>

<div class="mb-3 d-flex gap-2 align-items-end">
    <div>
        <label class="form-label">Ano</label>
        <input type="number" class="form-control" @bind="_year" min="2020" max="2100" />
    </div>
    <button class="btn btn-primary" @onclick="Generate">Gerar RPB</button>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}

@if (_reportId is not null)
{
    <div class="d-flex gap-2 mb-4">
        <a class="btn btn-outline-secondary" href="@Nav.ToAbsoluteUri($"/api/admin/aml-reports/{_reportId}/export")" target="_blank">Exportar JSON (interno)</a>
        <a class="btn btn-outline-primary" href="@Nav.ToAbsoluteUri($"/api/admin/aml-reports/{_reportId}/export?format=bdp")" target="_blank">Exportar XML BdP</a>
        <button class="btn btn-success" @onclick="SubmitToBdp">Marcar submetido à BdP</button>
    </div>
}

<div class="card">
    <div class="card-header">Histórico de relatórios</div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead>
            <tr><th>Ano</th><th>Estado</th><th>Gerado</th><th>Ref. BdP</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var r in _reports)
            {
                <tr class="@(r.Id == _reportId ? "table-active" : "")">
                    <td>@r.ReportingYear</td>
                    <td><span class="badge @StatusBadge(r.Status)">@r.Status</span></td>
                    <td>@r.GeneratedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td>@(r.BdpReferenceNumber ?? "—")</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-link" @onclick="() => SelectReport(r.Id)">Seleccionar</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@code {
    private int _year = DateTime.UtcNow.Year;
    private Guid? _reportId;
    private string? _message;
    private IReadOnlyList<AmlComplianceReportListItemDto> _reports = [];

    protected override async Task OnInitializedAsync() => await ReloadListAsync();

    private async Task ReloadListAsync() =>
        _reports = await Mediator.Send(new ListAmlComplianceReportsQuery());

    private void SelectReport(Guid id)
    {
        _reportId = id;
        _message = null;
    }

    private async Task Generate()
    {
        _reportId = await Mediator.Send(new GenerateAmlReportCommand(_year, "admin"));
        _message = $"RPB {_year} gerado (id: {_reportId}).";
        await ReloadListAsync();
    }

    private async Task SubmitToBdp()
    {
        if (_reportId is null) return;
        var reference = await Mediator.Send(new SubmitAmlReportToBdpCommand(_reportId.Value, "admin"));
        _message = $"Submetido à BdP — referência {reference}.";
        await ReloadListAsync();
    }

    private static string StatusBadge(AmlReportStatus status) => status switch
    {
        AmlReportStatus.Submitted => "bg-success",
        _ => "bg-secondary"
    };
}
