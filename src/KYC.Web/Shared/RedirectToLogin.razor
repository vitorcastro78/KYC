@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

@code {
    private bool _redirected;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _redirected)
            return;

        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            return;

        _redirected = true;

        var path = new Uri(Nav.Uri).AbsolutePath;
        if (path.Contains("/Identity/Account/Login", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/Identity/Account/Login", forceLoad: true);
            return;
        }

        var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
        var returnUrl = ReturnUrlNormalizer.Normalize(
            "/" + (string.IsNullOrWhiteSpace(relativePath) ? "dashboard" : relativePath.TrimStart('/')));

        Nav.NavigateTo($"/Identity/Account/Login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
    }
}
