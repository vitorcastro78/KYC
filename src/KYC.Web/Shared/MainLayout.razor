@inherits LayoutComponentBase

<PageTitle>KYC Intelligence Platform</PageTitle>

<div class="page app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="main-area">
        <header class="top-row auth px-4">
            <div class="d-flex align-items-center gap-3 w-100 justify-content-between">
                <div>
                    <h2 class="page-title mb-0">Risk & Compliance Workspace</h2>
                    <small class="text-muted">Corporate KYC · Due Diligence</small>
                </div>
                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center gap-2">
                            <div class="user-pill">
                                <span class="oi oi-person" aria-hidden="true"></span>
                                <span>@context.User.Identity?.Name</span>
                            </div>
                            <a class="btn btn-sm btn-outline-secondary" href="/Identity/Account/Manage">Conta</a>
                            <a class="btn btn-sm btn-outline-danger" href="/Identity/Account/Logout">Sair</a>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <article class="content px-4 pb-4">
            @Body
        </article>
    </main>
</div>
