<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <AuthorizeView>
                        <Authorized Context="authContext">
                            <div class="p-4">
                                <h2 class="h5">Sem permissão</h2>
                                <p class="text-muted mb-3">
                                    A sessão está activa (@authContext.User.Identity?.Name), mas esta página exige perfil de analista ou superior.
                                </p>
                                <a class="btn btn-primary me-2" href="/Identity/Account/AccessDenied">Detalhes</a>
                                <a class="btn btn-outline-secondary" href="/Identity/Account/Logout">Terminar sessão</a>
                            </div>
                        </Authorized>
                        <NotAuthorized Context="anonContext">
                            <RedirectToLogin />
                        </NotAuthorized>
                    </AuthorizeView>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Não encontrado</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Nada neste endereço.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
