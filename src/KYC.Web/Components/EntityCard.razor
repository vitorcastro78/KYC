@using KYC.Application.Dtos
@using KYC.Domain.Enums
@using KYC.Web.Services
<div class="card h-100">
    <div class="card-body">
        <h6 class="card-title">@Party.Name</h6>
        @if (!string.IsNullOrEmpty(Party.Nif))
        {
            <div class="small text-muted">NIF: @Party.Nif</div>
        }
        <div class="small text-muted">@RoleLabel(Party.Role) · profundidade @Party.UboDepthLevel</div>
        @if (ComplianceUiLabels.RequiresIdentityVerification(Party.Role) || Party.VerificationStatus != IdentityVerificationStatus.Pending)
        {
            <div class="mt-2">
                <IdentityVerificationBadge Status="Party.VerificationStatus" Method="Party.VerificationMethod" />
                @if (!string.IsNullOrWhiteSpace(Party.VerificationUrl) && Party.VerificationStatus == IdentityVerificationStatus.Pending)
                {
                    <a class="small d-block mt-1" href="@Party.VerificationUrl" target="_blank" rel="noopener noreferrer">Abrir verificação ↗</a>
                }
            </div>
        }
        <div class="mt-2">
            @if (Party.IsPep) { <span class="badge bg-info me-1">PEP</span> }
            @if (Party.IsSanctioned) { <span class="badge bg-danger me-1">Sanções</span> }
            @if (Party.IsOffshore) { <span class="badge bg-warning text-dark">Offshore</span> }
        </div>
        <div class="mt-2 small">Participação: @Party.OwnershipPercentage%</div>
        <div class="mt-2 d-flex flex-wrap gap-2">
            @if (CaseId is { } caseId)
            {
                <a class="btn btn-sm btn-outline-secondary" href="/cases/@caseId/parties/@Party.Id">Detalhe</a>
            }
            @if (ShowTriageButton)
            {
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => OnTriage.InvokeAsync(Party.Id)">Triagens</button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public CasePartyDto Party { get; set; } = default!;
    [Parameter] public Guid? CaseId { get; set; }
    [Parameter] public bool ShowTriageButton { get; set; }
    [Parameter] public EventCallback<Guid> OnTriage { get; set; }

    private static string RoleLabel(KYC.Domain.Enums.EntityRole role) => role switch
    {
        KYC.Domain.Enums.EntityRole.Target => "Tomador",
        KYC.Domain.Enums.EntityRole.Shareholder => "Accionista",
        KYC.Domain.Enums.EntityRole.Ubo => "UBO",
        KYC.Domain.Enums.EntityRole.BoardMember => "Órgão social / direcção",
        KYC.Domain.Enums.EntityRole.Proxy => "Procurador",
        _ => role.ToString()
    };
}
