@using KYC.Application.Cases
@using KYC.Application.Dtos
@using KYC.Application.Interfaces
@using KYC.Domain.Enums
@using KYC.Web.Services
@inject IMediator Mediator
@inject ToastService Toast
@inject ICurrentAnalystAccessor AnalystAccessor

<div class="party-identity-panel @CompactClass">
    <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
        <div>
            @if (ShowName)
            {
                <strong>@Party.Name</strong>
                <span class="text-muted small ms-1">(@RoleLabel(Party.Role))</span>
            }
            <div class="mt-1 d-flex flex-wrap align-items-center gap-1">
                <IdentityVerificationBadge Status="Party.VerificationStatus" Method="Party.VerificationMethod" ShowMethod="@(!Compact)" />
                @if (!string.IsNullOrWhiteSpace(Party.VerificationSessionId))
                {
                    <span class="text-muted small" title="ID da sessão">Sessão: <code class="small">@ShortSession(Party.VerificationSessionId)</code></span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Party.VerificationUrl) && Party.VerificationStatus == IdentityVerificationStatus.Pending)
            {
                <a class="small d-inline-block mt-1" href="@Party.VerificationUrl" target="_blank" rel="noopener noreferrer">Abrir portal de verificação ↗</a>
            }
        </div>
        <div class="d-flex gap-1 flex-wrap">
            @if (Party.VerificationStatus != IdentityVerificationStatus.Verified)
            {
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => _showVerification = true">
                    Verificar identidade
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _showManualVerification = true">
                    Verificado manualmente (sem API)
                </button>
            }
            @if (Party.RcbeDiscrepancyDetected && !Party.RcbeDiscrepancyReported)
            {
                <button type="button" class="btn btn-sm btn-outline-warning" @onclick="ReportRcbe">
                    Reportar discrepância RCBE
                </button>
            }
        </div>
    </div>
</div>

@if (_showManualVerification)
{
    <div class="modal show d-block compliance-modal" tabindex="-1">
        <div class="modal-backdrop fade show" @onclick="CloseManualVerificationModal"></div>
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Verificação manual — @Party.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseManualVerificationModal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">
                        Contingência quando o prestador digital falha e não há verificação presencial (Aviso 1/2022 BdP).
                    </p>
                    <label class="form-label">Justificação *</label>
                    <textarea class="form-control" rows="3" @bind="_manualJustification" placeholder="Mín. 20 caracteres — fundamento e meios de verificação"></textarea>
                    <label class="form-label mt-2">Referência documental (opcional)</label>
                    <input class="form-control" @bind="_manualDocRef" placeholder="Ex.: BI/Cartão de cidadão n.º …" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseManualVerificationModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmManualVerification">Registar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showVerification)
{
    <div class="modal show d-block compliance-modal" tabindex="-1">
        <div class="modal-backdrop fade show" @onclick="CloseVerificationModal"></div>
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Verificação — @Party.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseVerificationModal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted">Aviso 1/2022 BdP — escolha o meio de verificação da identidade.</p>
                    <label class="form-label">Método</label>
                    <select class="form-select" @bind="_verificationMethod">
                        <option value="@IdentityVerificationMethod.VideoConference">Videoconferência</option>
                        <option value="@IdentityVerificationMethod.CMD">Chave Móvel Digital</option>
                        <option value="@IdentityVerificationMethod.Presential">Presencial</option>
                        <option value="@IdentityVerificationMethod.QualifiedSignature">Assinatura qualificada eIDAS</option>
                    </select>
                    @if (_verificationMethod == IdentityVerificationMethod.Presential)
                    {
                        <label class="form-label mt-2">Referência do documento</label>
                        <input class="form-control" @bind="_presentialDocRef" placeholder="Ex.: BI n.º …" />
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseVerificationModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmVerification">Iniciar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public CasePartyDto Party { get; set; } = default!;
    [Parameter, EditorRequired] public Guid CaseId { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool ShowName { get; set; } = true;

    private bool _showVerification;
    private bool _showManualVerification;
    private IdentityVerificationMethod _verificationMethod = IdentityVerificationMethod.VideoConference;
    private string _presentialDocRef = "";
    private string _manualJustification = "";
    private string _manualDocRef = "";

    private string CompactClass => Compact ? "party-identity-panel--compact" : "";

    private async Task<string> AnalystIdAsync() => await AnalystAccessor.GetAnalystIdAsync();

    private static string ShortSession(string id) =>
        id.Length <= 12 ? id : id[..8] + "…";

    private static string RoleLabel(EntityRole role) => role switch
    {
        EntityRole.Ubo => "UBO",
        EntityRole.BoardMember => "Órgão social",
        EntityRole.Proxy => "Procurador",
        EntityRole.Shareholder => "Accionista",
        EntityRole.Target => "Tomador",
        _ => role.ToString()
    };

    private void CloseVerificationModal() => _showVerification = false;

    private void CloseManualVerificationModal() => _showManualVerification = false;

    private async Task ConfirmManualVerification()
    {
        try
        {
            await Mediator.Send(new RecordManualIdentityVerificationCommand(
                CaseId,
                Party.Id,
                await AnalystIdAsync(),
                _manualJustification,
                string.IsNullOrWhiteSpace(_manualDocRef) ? null : _manualDocRef.Trim()));
            Toast.Show("Verificação manual registada.", ToastLevel.Success);
            _manualJustification = "";
            _manualDocRef = "";
            CloseManualVerificationModal();
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Toast.Show(ex.Message, ToastLevel.Error);
        }
    }

    private async Task ConfirmVerification()
    {
        if (_verificationMethod == IdentityVerificationMethod.Presential)
        {
            await Mediator.Send(new RecordPresentialVerificationCommand(
                CaseId, Party.Id, await AnalystIdAsync(), _presentialDocRef));
            Toast.Show("Verificação presencial registada.", ToastLevel.Success);
        }
        else
        {
            var session = await Mediator.Send(new InitiateEntityVerificationCommand(
                CaseId, Party.Id, _verificationMethod, await AnalystIdAsync()));
            Toast.Show(
                string.IsNullOrWhiteSpace(session.VerificationUrl)
                    ? "Sessão de verificação iniciada."
                    : "Sessão iniciada — use «Abrir portal de verificação».",
                ToastLevel.Success);
        }

        CloseVerificationModal();
        await OnChanged.InvokeAsync();
    }

    private async Task ReportRcbe()
    {
        await Mediator.Send(new ReportRcbeDiscrepancyCommand(CaseId, Party.Id, await AnalystIdAsync()));
        Toast.Show("Discrepância RCBE reportada.", ToastLevel.Success);
        await OnChanged.InvokeAsync();
    }
}
