@using KYC.Application.Dtos
@using KYC.Application.Cases
@using KYC.Domain.Enums
@inject IMediator Mediator
@inject ToastService Toast

@if (Case is not null)
{
    <div class="card mb-3 border-warning">
        <div class="card-header">
            <h3 class="h6 mb-0">Conformidade BdP</h3>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="small text-muted">Diligência aplicada</div>
                    <strong>@Case.DueDiligenceLevel</strong>
                    @if (!string.IsNullOrWhiteSpace(Case.DueDiligenceJustification))
                    {
                        <div class="small">@Case.DueDiligenceJustification</div>
                    }
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">SAR / UIF</div>
                    <span class="badge @SarBadgeClass">@Case.SarStatus</span>
                    @if (!string.IsNullOrWhiteSpace(Case.SarReferenceNumber))
                    {
                        <div class="small">Ref: @Case.SarReferenceNumber</div>
                    }
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">Próxima revisão</div>
                    @(Case.NextReviewDue?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")
                </div>
            </div>

            <div class="row g-2 mb-3 small">
                <div class="col-md-4">
                    <span class="text-muted">Relação:</span> @RelationshipLabel(Case.RelationshipType)
                </div>
                @if (!string.IsNullOrWhiteSpace(Case.LegalBasisRef))
                {
                    <div class="col-md-8"><span class="text-muted">Base legal:</span> @Case.LegalBasisRef</div>
                }
            </div>

            @if (Case.AssetFreezeNotified)
            {
                <div class="alert alert-danger">
                    <strong>Congelamento de ativos notificado</strong>
                    @(Case.AssetFreezeNotifiedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "")
                    @if (!string.IsNullOrWhiteSpace(Case.AssetFreezeConfirmationRef))
                    {
                        <span> — Ref: @Case.AssetFreezeConfirmationRef</span>
                    }
                </div>
            }

            @if (Case.SuggestSar)
            {
                <div class="alert alert-warning">
                    Este caso reúne condições para comunicação à UIF.
                    <button type="button" class="btn btn-sm btn-warning ms-2" @onclick="() => _showSar = true">Comunicar à UIF</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => _showSarNotRequired = true">Não aplicável</button>
                </div>
            }

            @if (Case.DueDiligenceLevel == DueDiligenceLevel.Enhanced)
            {
                <div class="mb-3">
                    <label class="form-label">Origem dos fundos (EDD obrigatório)</label>
                    <textarea class="form-control" rows="2" @bind="_fundsOrigin"></textarea>
                    <button type="button" class="btn btn-sm btn-primary mt-2" @onclick="SaveFundsOrigin">Guardar origem</button>
                </div>
            }

            <h4 class="h6">Verificação de identidade</h4>
            @foreach (var p in Case.Parties.Where(x => x.Role is EntityRole.Ubo or EntityRole.BoardMember or EntityRole.Proxy))
            {
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div>
                        <strong>@p.Name</strong> <span class="text-muted small">(@p.Role)</span>
                        <div><span class="badge @VerificationBadge(p.VerificationStatus)">@p.VerificationStatus</span></div>
                    </div>
                    <div class="d-flex gap-1 flex-wrap">
                        @if (p.VerificationStatus != IdentityVerificationStatus.Verified)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    @onclick="() => OpenVerificationModal(p.Id)">
                                Verificar identidade
                            </button>
                        }
                        @if (p.RcbeDiscrepancyDetected && !p.RcbeDiscrepancyReported)
                        {
                            <button type="button" class="btn btn-sm btn-outline-warning"
                                    @onclick="() => ReportRcbe(p.Id)">
                                Reportar discrepância RCBE
                            </button>
                        }
                    </div>
                </div>
            }

            @{
                var canApprove = Case.CanApproveMessage;
            }
            @if (!string.IsNullOrWhiteSpace(canApprove))
            {
                <div class="alert alert-danger mt-3 mb-0">@canApprove</div>
            }
        </div>
    </div>

    @if (_showSar)
    {
        <div class="modal show d-block" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Comunicação à UIF</h5></div>
                    <div class="modal-body">
                        <textarea class="form-control" rows="6" @bind="_sarNarrative" placeholder="Narrativa (mín. 200 caracteres)"></textarea>
                        <small class="text-muted">@(_sarNarrative?.Length ?? 0) / 200 caracteres</small>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" @bind="_sarUrgent" id="sarUrgent" />
                            <label class="form-check-label" for="sarUrgent">Urgente (comunicação imediata)</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showSar = false">Cancelar</button>
                        <button type="button" class="btn btn-danger" disabled="@((_sarNarrative?.Length ?? 0) < 200)" @onclick="SubmitSar">Submeter SAR</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_showSarNotRequired)
    {
        <div class="modal show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">SAR não aplicável</h5></div>
                    <div class="modal-body">
                        <textarea class="form-control" rows="4" @bind="_sarNotRequiredJustification" placeholder="Justificação (mín. 50 caracteres)"></textarea>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showSarNotRequired = false">Cancelar</button>
                        <button type="button" class="btn btn-primary" disabled="@((_sarNotRequiredJustification?.Length ?? 0) < 50)" @onclick="MarkSarNotRequired">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_showVerification && _verificationPartyId is not null)
    {
        <div class="modal show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Método de verificação (Aviso 1/2022)</h5></div>
                    <div class="modal-body">
                        <select class="form-select" @bind="_verificationMethod">
                            <option value="@IdentityVerificationMethod.VideoConference">Videoconferência</option>
                            <option value="@IdentityVerificationMethod.CMD">Chave Móvel Digital</option>
                            <option value="@IdentityVerificationMethod.Presential">Presencial</option>
                            <option value="@IdentityVerificationMethod.QualifiedSignature">Assinatura qualificada eIDAS</option>
                        </select>
                        @if (_verificationMethod == IdentityVerificationMethod.Presential)
                        {
                            <input class="form-control mt-2" @bind="_presentialDocRef" placeholder="Referência do documento" />
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseVerificationModal">Cancelar</button>
                        <button type="button" class="btn btn-primary" @onclick="ConfirmVerification">Iniciar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public KycCaseDetailDto? Case { get; set; }
    [Parameter] public Guid CaseId { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _showSar;
    private bool _showSarNotRequired;
    private bool _showVerification;
    private Guid? _verificationPartyId;
    private IdentityVerificationMethod _verificationMethod = IdentityVerificationMethod.VideoConference;
    private string _presentialDocRef = "";
    private string _sarNarrative = "";
    private string _sarNotRequiredJustification = "";
    private bool _sarUrgent;
    private string _fundsOrigin = "";

    protected override void OnParametersSet()
    {
        _fundsOrigin = Case?.FundsOriginDescription ?? "";
        if (Case?.SuggestSar == true && string.IsNullOrWhiteSpace(_sarNarrative))
            _sarNarrative = string.Join("\n", Case.Signals.Where(s => s.Severity >= SignalSeverity.High).Select(s => s.Description));
    }

    private static string RelationshipLabel(RelationshipType t) => t switch
    {
        RelationshipType.Occasional => "Ocasional",
        _ => "Continuada"
    };

    private string SarBadgeClass => Case?.SarStatus switch
    {
        SarStatus.Submitted => "bg-danger",
        SarStatus.Pending => "bg-warning text-dark",
        SarStatus.NotRequired => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static string VerificationBadge(IdentityVerificationStatus s) => s switch
    {
        IdentityVerificationStatus.Verified => "bg-success",
        IdentityVerificationStatus.Failed => "bg-danger",
        IdentityVerificationStatus.Expired => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private void OpenVerificationModal(Guid partyId)
    {
        _verificationPartyId = partyId;
        _showVerification = true;
    }

    private void CloseVerificationModal()
    {
        _showVerification = false;
        _verificationPartyId = null;
    }

    private async Task ConfirmVerification()
    {
        if (_verificationPartyId is null) return;
        if (_verificationMethod == IdentityVerificationMethod.Presential)
        {
            await Mediator.Send(new RecordPresentialVerificationCommand(
                CaseId, _verificationPartyId.Value, "dev-user", _presentialDocRef));
            Toast.Show("Verificação presencial registada.", ToastLevel.Success);
        }
        else
        {
            await Mediator.Send(new InitiateEntityVerificationCommand(
                CaseId, _verificationPartyId.Value, _verificationMethod, "dev-user"));
            Toast.Show("Sessão de verificação iniciada.", ToastLevel.Success);
        }
        CloseVerificationModal();
        await OnChanged.InvokeAsync();
    }

    private async Task MarkSarNotRequired()
    {
        await Mediator.Send(new MarkSarNotRequiredCommand(CaseId, "dev-user", _sarNotRequiredJustification));
        Toast.Show("SAR marcado como não aplicável.", ToastLevel.Success);
        _showSarNotRequired = false;
        await OnChanged.InvokeAsync();
    }

    private async Task ReportRcbe(Guid partyId)
    {
        await Mediator.Send(new ReportRcbeDiscrepancyCommand(CaseId, partyId, "dev-user"));
        Toast.Show("Discrepância RCBE reportada.", ToastLevel.Success);
        await OnChanged.InvokeAsync();
    }

    private async Task SubmitSar()
    {
        var result = await Mediator.Send(new SubmitSarCommand(CaseId, _sarNarrative, "dev-user", _sarUrgent));
        if (result.IsSuccess)
        {
            Toast.Show($"SAR submetido: {result.ReferenceNumber}", ToastLevel.Success);
            _showSar = false;
            await OnChanged.InvokeAsync();
        }
        else
            Toast.Show(result.ErrorMessage ?? "Falha SAR", ToastLevel.Error);
    }

    private async Task SaveFundsOrigin()
    {
        await Mediator.Send(new SetFundsOriginCommand(CaseId, _fundsOrigin, true, null));
        Toast.Show("Origem dos fundos registada.", ToastLevel.Success);
        await OnChanged.InvokeAsync();
    }
}
