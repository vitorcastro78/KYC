@using KYC.Application.Dtos

@using KYC.Application.Cases

@using KYC.Application.Interfaces

@using KYC.Domain.Enums

@using KYC.Web.Services

@inject IMediator Mediator

@inject ToastService Toast

@inject ICurrentAnalystAccessor AnalystAccessor



@if (Case is not null)

{

    <div class="card mb-3 border-warning">

        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">

            <h3 class="h6 mb-0">Conformidade BdP</h3>

            @if (CanManageSar)

            {

                <div class="d-flex flex-wrap gap-1">

                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => _showSar = true">Comunicar à UIF</button>

                    @if (Case.SarStatus is SarStatus.None or SarStatus.Pending)

                    {

                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _showSarNotRequired = true">SAR não aplicável</button>

                    }

                </div>

            }

        </div>

        <div class="card-body">

            <div class="row g-3 mb-3">

                <div class="col-md-4">

                    <div class="small text-muted">Diligência aplicada</div>

                    <strong>@DdcLabel(Case.DueDiligenceLevel)</strong>

                    @if (!string.IsNullOrWhiteSpace(Case.DueDiligenceJustification))

                    {

                        <div class="small">@Case.DueDiligenceJustification</div>

                    }

                </div>

                <div class="col-md-4">

                    <div class="small text-muted">SAR / UIF</div>

                    <span class="badge @ComplianceUiLabels.SarBadgeClass(Case.SarStatus)">@ComplianceUiLabels.SarStatusLabel(Case.SarStatus)</span>

                    @if (Case.SarStatus == SarStatus.Pending)

                    {

                        <div class="mt-2">

                            @if (!string.IsNullOrWhiteSpace(Case.SarPendingManualReason))

                            {

                                <div class="alert alert-warning py-1 px-2 small mb-2">@Case.SarPendingManualReason</div>

                            }

                            <label class="form-label small mb-1">Registo manual UIF (API indisponível)</label>

                            <div class="input-group input-group-sm">

                                <input class="form-control" @bind="_manualUifRef" placeholder="Ref. UIF oficial" />

                                <button type="button" class="btn btn-outline-primary" @onclick="RegisterManualUif">Registar</button>

                            </div>

                        </div>

                    }

                    @if (!string.IsNullOrWhiteSpace(Case.SarReferenceNumber))

                    {

                        <div class="small mt-1">Ref: @Case.SarReferenceNumber</div>

                        <button type="button" class="btn btn-link btn-sm p-0" @onclick="QueryUifStatus" disabled="@_uifStatusLoading">

                            @(_uifStatusLoading ? "A consultar…" : "Estado na UIF")

                        </button>

                        @if (_uifStatus is not null)

                        {

                            <div class="small text-muted">UIF: @_uifStatus.Status (@_uifStatus.LastUpdated?.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</div>

                        }

                    }

                </div>

                <div class="col-md-4">

                    <div class="small text-muted">Próxima revisão</div>

                    @(Case.NextReviewDue?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")

                </div>

            </div>



            <div class="row g-2 mb-3 small">

                <div class="col-md-4">

                    <span class="text-muted">Relação:</span> @RelationshipLabel(Case.RelationshipType)

                </div>

                @if (!string.IsNullOrWhiteSpace(Case.LegalBasisRef))

                {

                    <div class="col-md-8"><span class="text-muted">Base legal:</span> @Case.LegalBasisRef</div>

                }

            </div>



            @if (Case.AssetFreezeNotified)

            {

                <div class="alert alert-danger">

                    <strong>Congelamento de ativos notificado</strong>

                    @(Case.AssetFreezeNotifiedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "")

                    @if (!string.IsNullOrWhiteSpace(Case.AssetFreezeConfirmationRef))

                    {

                        <span> — Ref: @Case.AssetFreezeConfirmationRef</span>

                    }

                </div>

            }

            else if (Case.NeedsManualAssetFreezeRegistration)

            {

                <div class="alert alert-danger">

                    <strong>Congelamento BdP pendente</strong> — a API falhou ou não está configurada. Registe a referência de confirmação manualmente.

                    <div class="input-group input-group-sm mt-2">

                        <input class="form-control" @bind="_manualFreezeRef" placeholder="Ref. confirmação BdP" />

                        <button type="button" class="btn btn-outline-light" @onclick="RegisterManualFreeze">Registar</button>

                    </div>

                </div>

            }



            @if (Case.SuggestSar && Case.SarStatus != SarStatus.Submitted)

            {

                <div class="alert alert-warning mb-3">

                    <strong>SAR sugerido</strong> — o pipeline identificou condições para comunicação à UIF (sinais elevados ou PEP/sanções).

                    <button type="button" class="btn btn-sm btn-warning ms-2" @onclick="() => _showSar = true">Comunicar à UIF</button>

                </div>

            }



            @if (Case.DueDiligenceLevel == DueDiligenceLevel.Enhanced)

            {

                <div class="mb-3">

                    <label class="form-label">Origem dos fundos (EDD obrigatório)</label>

                    <textarea class="form-control" rows="2" @bind="_fundsOrigin"></textarea>

                    <button type="button" class="btn btn-sm btn-primary mt-2" @onclick="SaveFundsOrigin">Guardar origem</button>

                </div>

            }



            @if (Case.SarHistory is { Count: > 0 })

            {

                <h4 class="h6 mt-3">Histórico SAR / UIF</h4>

                <table class="table table-sm mb-3">

                    <thead><tr><th>Data</th><th>Acção</th><th>Actor</th><th>Detalhe</th></tr></thead>

                    <tbody>

                    @foreach (var h in Case.SarHistory)

                    {

                        <tr>

                            <td>@h.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>

                            <td>@SarActionLabel(h.Action)</td>

                            <td>@h.ActorId</td>

                            <td class="small">@(h.Details ?? "—")</td>

                        </tr>

                    }

                    </tbody>

                </table>

            }



            @{

                var identityParties = Case.Parties.Where(x => ComplianceUiLabels.RequiresIdentityVerification(x.Role)).ToList();

            }

            @if (identityParties.Count > 0)

            {

                <h4 class="h6">Verificação de identidade (Aviso 1/2022)</h4>

                @foreach (var p in identityParties)

                {

                    <div class="border-bottom py-2">

                        <PartyIdentityPanel Party="p" CaseId="CaseId" OnChanged="OnChanged" />

                    </div>

                }

            }



            @if (!string.IsNullOrWhiteSpace(Case.CanApproveMessage))

            {

                <div class="alert alert-danger mt-3 mb-0">

                    <strong>Aprovação bloqueada:</strong> @Case.CanApproveMessage

                </div>

            }

        </div>

    </div>



    <SarActionModals CaseId="CaseId"

                     ShowSubmit="_showSar"

                     ShowNotRequired="_showSarNotRequired"

                     SuggestedNarrative="_suggestedNarrative"

                     OnChanged="OnChanged"

                     OnCloseSubmit="CloseSar"

                     OnCloseNotRequired="CloseSarNotRequired" />

}



@code {

    [Parameter] public KycCaseDetailDto? Case { get; set; }

    [Parameter] public Guid CaseId { get; set; }

    [Parameter] public EventCallback OnChanged { get; set; }



    private bool _showSar;

    private bool _showSarNotRequired;

    private string _fundsOrigin = "";

    private bool _uifStatusLoading;

    private UifSubmissionStatusDto? _uifStatus;

    private string _manualUifRef = "";

    private string _manualFreezeRef = "";



    private string? _suggestedNarrative =>

        Case is null ? null : string.Join("\n", Case.Signals.Where(s => s.Severity >= SignalSeverity.High).Select(s => s.Description));



    private bool CanManageSar =>

        Case is not null && Case.SarStatus is not SarStatus.Submitted and not SarStatus.NotRequired;



    private async Task<string> AnalystIdAsync() => await AnalystAccessor.GetAnalystIdAsync();



    protected override void OnParametersSet() =>

        _fundsOrigin = Case?.FundsOriginDescription ?? "";



    private static string DdcLabel(DueDiligenceLevel d) => d switch

    {

        DueDiligenceLevel.Simplified => "Simplificada",

        DueDiligenceLevel.Enhanced => "Reforçada (EDD)",

        _ => "Standard"

    };



    private static string RelationshipLabel(RelationshipType t) => t switch

    {

        RelationshipType.Occasional => "Ocasional",

        _ => "Continuada"

    };



    private static string SarActionLabel(string action) => action switch

    {

        "SarSubmitted" => "SAR submetido",

        "SarUrgentSubmitted" => "SAR urgente",

        "SarQueued" => "SAR em fila",

        "SarManualRegistered" => "SAR manual UIF",

        "SarApiFailedPendingManual" => "SAR pendente (falha API)",

        "AssetFreezeManualRegistered" => "Congelamento manual BdP",

        "AssetFreezeNotificationFailed" => "Congelamento API falhou",

        "SarNotRequired" => "SAR não aplicável",

        "SarSuggested" => "SAR sugerido",

        _ => action

    };



    private void CloseSar() => _showSar = false;

    private void CloseSarNotRequired() => _showSarNotRequired = false;



    private async Task QueryUifStatus()

    {

        if (string.IsNullOrWhiteSpace(Case?.SarReferenceNumber))

            return;

        _uifStatusLoading = true;

        try

        {

            _uifStatus = await Mediator.Send(new GetUifSubmissionStatusQuery(Case.SarReferenceNumber));

            Toast.Show($"Estado UIF: {_uifStatus.Status}", ToastLevel.Info);

        }

        catch (Exception ex)

        {

            Toast.Show(ex.Message, ToastLevel.Error);

        }

        finally

        {

            _uifStatusLoading = false;

        }

    }



    private async Task RegisterManualUif()

    {

        if (string.IsNullOrWhiteSpace(_manualUifRef))

        {

            Toast.Show("Indique a referência UIF.", ToastLevel.Warning);

            return;

        }



        await Mediator.Send(new RegisterManualUifReferenceCommand(CaseId, _manualUifRef.Trim(), await AnalystIdAsync()));

        Toast.Show("Referência UIF registada.", ToastLevel.Success);

        _manualUifRef = "";

        await OnChanged.InvokeAsync();

    }



    private async Task RegisterManualFreeze()

    {

        if (string.IsNullOrWhiteSpace(_manualFreezeRef))

        {

            Toast.Show("Indique a referência BdP.", ToastLevel.Warning);

            return;

        }



        await Mediator.Send(new RegisterManualAssetFreezeReferenceCommand(

            CaseId, _manualFreezeRef.Trim(), await AnalystIdAsync()));

        Toast.Show("Congelamento BdP registado.", ToastLevel.Success);

        _manualFreezeRef = "";

        await OnChanged.InvokeAsync();

    }



    private async Task SaveFundsOrigin()

    {

        await Mediator.Send(new SetFundsOriginCommand(CaseId, _fundsOrigin, true, null));

        Toast.Show("Origem dos fundos registada.", ToastLevel.Success);

        await OnChanged.InvokeAsync();

    }

}


