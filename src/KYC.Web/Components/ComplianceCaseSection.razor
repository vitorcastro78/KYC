@using KYC.Application.Dtos
@using KYC.Application.Cases
@using KYC.Domain.Enums
@inject IMediator Mediator
@inject ToastService Toast

@if (Case is not null)
{
    <div class="card mb-3 border-warning">
        <div class="card-header">
            <h3 class="h6 mb-0">Conformidade BdP</h3>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="small text-muted">Diligência aplicada</div>
                    <strong>@Case.DueDiligenceLevel</strong>
                    @if (!string.IsNullOrWhiteSpace(Case.DueDiligenceJustification))
                    {
                        <div class="small">@Case.DueDiligenceJustification</div>
                    }
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">SAR / UIF</div>
                    <span class="badge @SarBadgeClass">@Case.SarStatus</span>
                    @if (!string.IsNullOrWhiteSpace(Case.SarReferenceNumber))
                    {
                        <div class="small">Ref: @Case.SarReferenceNumber</div>
                    }
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">Próxima revisão</div>
                    @(Case.NextReviewDue?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")
                </div>
            </div>

            @if (Case.SuggestSar)
            {
                <div class="alert alert-warning">
                    Este caso reúne condições para comunicação à UIF.
                    <button type="button" class="btn btn-sm btn-warning ms-2" @onclick="() => _showSar = true">Comunicar à UIF</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => _showSarNotRequired = true">Não aplicável</button>
                </div>
            }

            @if (Case.DueDiligenceLevel == DueDiligenceLevel.Enhanced)
            {
                <div class="mb-3">
                    <label class="form-label">Origem dos fundos (EDD obrigatório)</label>
                    <textarea class="form-control" rows="2" @bind="_fundsOrigin"></textarea>
                    <button type="button" class="btn btn-sm btn-primary mt-2" @onclick="SaveFundsOrigin">Guardar origem</button>
                </div>
            }

            <h4 class="h6">Verificação de identidade</h4>
            @foreach (var p in Case.Parties.Where(x => x.Role is EntityRole.Ubo or EntityRole.BoardMember or EntityRole.Proxy))
            {
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div>
                        <strong>@p.Name</strong> <span class="text-muted small">(@p.Role)</span>
                        <div><span class="badge @VerificationBadge(p.VerificationStatus)">@p.VerificationStatus</span></div>
                    </div>
                    @if (p.VerificationStatus != IdentityVerificationStatus.Verified)
                    {
                        <button type="button" class="btn btn-sm btn-outline-primary"
                                @onclick="() => InitiateVerification(p.Id, IdentityVerificationMethod.VideoConference)">
                            Iniciar verificação
                        </button>
                    }
                </div>
            }

            @{
                var canApprove = Case.CanApproveMessage;
            }
            @if (!string.IsNullOrWhiteSpace(canApprove))
            {
                <div class="alert alert-danger mt-3 mb-0">@canApprove</div>
            }
        </div>
    </div>

    @if (_showSar)
    {
        <div class="modal show d-block" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header"><h5 class="modal-title">Comunicação à UIF</h5></div>
                    <div class="modal-body">
                        <textarea class="form-control" rows="6" @bind="_sarNarrative" placeholder="Narrativa (mín. 200 caracteres)"></textarea>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" @bind="_sarUrgent" id="sarUrgent" />
                            <label class="form-check-label" for="sarUrgent">Urgente (comunicação imediata)</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showSar = false">Cancelar</button>
                        <button type="button" class="btn btn-danger" @onclick="SubmitSar">Submeter SAR</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public KycCaseDetailDto? Case { get; set; }
    [Parameter] public Guid CaseId { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _showSar;
    private bool _showSarNotRequired;
    private string _sarNarrative = "";
    private bool _sarUrgent;
    private string _fundsOrigin = "";

    protected override void OnParametersSet()
    {
        _fundsOrigin = Case?.FundsOriginDescription ?? "";
        if (Case?.SuggestSar == true && string.IsNullOrWhiteSpace(_sarNarrative))
            _sarNarrative = string.Join("\n", Case.Signals.Where(s => s.Severity >= SignalSeverity.High).Select(s => s.Description));
    }

    private string SarBadgeClass => Case?.SarStatus switch
    {
        SarStatus.Submitted => "bg-danger",
        SarStatus.Pending => "bg-warning text-dark",
        SarStatus.NotRequired => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static string VerificationBadge(IdentityVerificationStatus s) => s switch
    {
        IdentityVerificationStatus.Verified => "bg-success",
        IdentityVerificationStatus.Failed => "bg-danger",
        IdentityVerificationStatus.Expired => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private async Task InitiateVerification(Guid partyId, IdentityVerificationMethod method)
    {
        await Mediator.Send(new InitiateEntityVerificationCommand(CaseId, partyId, method, "dev-user"));
        Toast.Show("Sessão de verificação iniciada.", ToastLevel.Success);
        await OnChanged.InvokeAsync();
    }

    private async Task SubmitSar()
    {
        var result = await Mediator.Send(new SubmitSarCommand(CaseId, _sarNarrative, "dev-user", _sarUrgent));
        if (result.IsSuccess)
        {
            Toast.Show($"SAR submetido: {result.ReferenceNumber}", ToastLevel.Success);
            _showSar = false;
            await OnChanged.InvokeAsync();
        }
        else
            Toast.Show(result.ErrorMessage ?? "Falha SAR", ToastLevel.Error);
    }

    private async Task SaveFundsOrigin()
    {
        await Mediator.Send(new SetFundsOriginCommand(CaseId, _fundsOrigin, true, null));
        Toast.Show("Origem dos fundos registada.", ToastLevel.Success);
        await OnChanged.InvokeAsync();
    }
}
